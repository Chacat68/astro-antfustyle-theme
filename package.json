{
  "name": "astro-antfustyle-theme",
  "version": "2.3.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "astro": "astro",
    "sync": "astro sync",
    "dev": "astro dev",
    "check": "astro check",
    "build": "astro build",
    "preview": "astro preview",
    "translate:blog": "node scripts/translate-blog.mjs",
    "format": "prettier . --check --ignore-unknown",
    "format:write": "prettier . --write --ignore-unknown --cache",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0 --cache",
    "lint:fix": "eslint . --fix --cache",
    "toolbar:on": "astro preferences enable devToolbar",
    "toolbar:off": "astro preferences disable devToolbar",
    "prepare": "simple-git-hooks",
    "postbuild": "pagefind --site dist --force-language zh-cn --exclude-selectors \"pre\" --include-characters \"<>\" && del-cli \"dist/pagefind/*ui*\" && node scripts/sync-pagefind-public.mjs",
    "seo:audit": "node scripts/seo-audit.mjs",
    "seo:fix-descriptions": "node scripts/fix-blog-descriptions.mjs",
    "test": "node --experimental-strip-types --test src/utils/*.test.ts"
  },
  "devDependencies": {
    "@ascorbic/feed-loader": "^2.0.1",
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/markdown-satteri": "0.3.0",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@atproto/api": "^0.17.2",
    "@eslint/js": "^9.37.0",
    "@expressive-code/plugin-collapsible-sections": "^0.44.0",
    "@expressive-code/plugin-line-numbers": "^0.44.0",
    "@iconify/json": "^2.2.394",
    "@types/node": "^24.7.2",
    "@types/nprogress": "^0.2.3",
    "@types/p5": "^1.7.7",
    "@types/three": "^0.185.1",
    "@typescript-eslint/parser": "^8.46.0",
    "@unocss/reset": "66.5.3",
    "astro": "^6.4.8",
    "astro-expressive-code": "^0.44.0",
    "astro-loader-bluesky-posts": "^1.2.5",
    "astro-loader-github-prs": "^2.0.1",
    "astro-loader-github-releases": "^3.0.1",
    "astro-robots-txt": "^1.0.0",
    "chalk": "^5.6.2",
    "del-cli": "^6.0.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "github-slugger": "^2.0.0",
    "globals": "^16.4.0",
    "html-entities": "^2.6.0",
    "isomorphic-dompurify": "^3.18.0",
    "lint-staged": "^15.5.1",
    "mdast-util-to-string": "^4.0.0",
    "nprogress": "^0.2.0",
    "p5": "^1.11.3",
    "pagefind": "^1.5.2",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-callouts": "^2.1.2",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-wrap-all": "^1.1.0",
    "remark-directive": "^4.0.0",
    "remark-directive-sugar": "^1.1.2",
    "remark-imgattr": "^1.0.5",
    "remark-math": "^6.0.0",
    "satori": "^0.18.3",
    "satori-html": "^0.3.2",
    "sharp": "^0.34.4",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "unist-util-visit": "^5.0.0",
    "unocss": "66.5.3",
    "viewerjs": "^1.11.7"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,mts,astro}": [
      "eslint"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "simple-git-hooks"
    ]
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@iconify/utils": "^3.1.4",
    "three": "^0.185.1"
  }
}
