---
import '@unocss/reset/tailwind.css'
import '~/styles/fonts.css'
import '~/styles/main.css'
import '~/styles/hud.css'
import '~/styles/prose.css'
import '~/styles/markdown.css'
import '~/styles/page.css'

import Head from '~/components/base/Head.astro'
import Background from '~/components/backgrounds/Background.astro'
import Link from '~/components/base/Link.astro'
import NavBar from '~/components/nav/NavBar.astro'
import BackLink from '~/components/widgets/BackLink.astro'
import Footer from '~/components/base/Footer.astro'
import ToTopButton from '~/components/widgets/ToTopButton.astro'
import Backdrop from '~/components/base/Backdrop.astro'

import { UI, FEATURES } from '~/config'
import { ensureTrailingSlash } from '~/utils/path'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { getLocale, useTranslations } from '~/i18n/translate'
import { localeToHtmlLang } from '~/i18n/locale-meta'

import type { AppLocale } from '~/i18n/locales'
import type { BgType } from '~/types'

interface Props {
  title?: string
  description?: string
  ogImage?: string | boolean
  bgType?: BgType | false
  pubDate?: string
  lastModDate?: string
  tags?: string[]
  category?: string
  availableLocales?: AppLocale[]
  canonicalLocale?: AppLocale
  noindex?: boolean
  /** 追加到 `<main>` 的 class（如首页全屏 Hero 去 padding） */
  mainClass?: string
  /** 首页展示台：隐藏导航栏、页脚与回到顶部 */
  minimalChrome?: boolean
}

const {
  title,
  description,
  ogImage,
  bgType,
  pubDate,
  lastModDate,
  tags,
  category,
  availableLocales,
  canonicalLocale,
  noindex,
  mainClass,
  minimalChrome = false,
} = Astro.props

const locale = getLocale(Astro.currentLocale)
const t = useTranslations(locale)
const localeHome = ensureTrailingSlash(getRelativeLocaleUrl(locale, ''))

let style: Record<string, string> = {}

const { slideEnterAnim } = FEATURES
const enableSlideEnterAnim = Array.isArray(slideEnterAnim) && slideEnterAnim[0]
if (enableSlideEnterAnim)
  style['--enter-step'] = `${slideEnterAnim[1].enterStep}ms`

const {
  externalLink: { newTab, cursorType },
} = UI
const hasCustomCursor =
  newTab && cursorType.length > 0 && cursorType !== 'pointer'
if (hasCustomCursor) style['--external-link-cursor'] = cursorType
---

<!doctype html>
<html lang={localeToHtmlLang(locale)}>
  <head>
    <Head
      {title}
      {description}
      {ogImage}
      {pubDate}
      {lastModDate}
      {tags}
      {category}
      {availableLocales}
      {canonicalLocale}
      {noindex}
    />
  </head>

  <body
    class="relative flex flex-col min-h-screen
      font-sans text-[var(--c-text)]"
    style={Object.keys(style).length !== 0 ? style : undefined}
    data-no-sliding={enableSlideEnterAnim ? undefined : ''}
  >
    <!-- Background -->
    {bgType && <Background type={bgType} />}

    <!-- Skip Link -->
    <Link
      href="#main"
      class="sr-only focus:(not-sr-only fixed start-1 top-1.5 op-20)"
    >
      {t('a11y.skipToContent')}
    </Link>

    <!-- Nav Bar（首页展示台由 GlitchHero 自带工具入口） -->
    {!minimalChrome && <NavBar />}

    <!-- Main -->
    <main
      id="main"
      class:list={['relative px-5 py-8 sm:(px-7 py-10)', mainClass]}
    >
      <!-- Content -->
      <slot />
      <!-- Share -->
      {
        ensureTrailingSlash(Astro.url.pathname) !== localeHome && (
          <footer class="slide-enter animate-delay-1000! prose mx-auto mt-8 print:hidden">
            <slot name="share" />
            <br />
            <BackLink />
          </footer>
        )
      }
      <!-- Comments -->
      <slot name="giscus" />
    </main>

    <!-- Footer -->
    {!minimalChrome && <Footer />}
    {!minimalChrome && <ToTopButton />}

    <!-- Panel Backdrop (on mobile) -->
    <Backdrop />

    <!-- Progress Bar -->
    <script>
      import nprogress from 'nprogress'

      document.addEventListener('astro:before-preparation', () => {
        nprogress.start()
      })

      document.addEventListener('astro:page-load', () => {
        nprogress.done()
      })
    </script>
  </body>
</html>
