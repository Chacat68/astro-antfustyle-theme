---
import { ClientRouter } from 'astro:transitions'
import { basename } from 'node:path'
import { getAbsoluteLocaleUrl, getRelativeLocaleUrl } from 'astro:i18n'

import { checkFileExistsInDir } from '../../../plugins/remark-generate-og-image'
import { withBasePath } from '~/utils/path'
import { formatPageTitle, truncateMetaDescription } from '~/utils/seo'
import { FEATURES, SITE, UI } from '~/config'
import { getLocale } from '~/i18n/translate'
import { isDefaultLocale } from '~/i18n/locales'
import { localeToHtmlLang, localeToOgLocale } from '~/i18n/locale-meta'

import type { AppLocale } from '~/i18n/locales'

interface Props {
  title?: string
  description?: string
  ogImage?: string | boolean
  pubDate?: string
  lastModDate?: string
  tags?: string[]
  category?: string
  availableLocales?: AppLocale[]
  canonicalLocale?: AppLocale
  noindex?: boolean
}

const {
  title,
  description,
  ogImage,
  pubDate,
  lastModDate,
  tags = [],
  category,
  availableLocales = ['zh', 'en'],
  canonicalLocale: canonicalLocaleProp,
  noindex = false,
} = Astro.props

const locale = getLocale(Astro.currentLocale)
const canonicalLocale = getLocale(canonicalLocaleProp ?? locale)

const pageTitle = formatPageTitle(title, SITE.title)

const pageDescription = truncateMetaDescription(
  description || SITE.description
)
const schemaName = title || SITE.title
const normalizedTags = tags.filter((tag) => tag.trim().length > 0)
const robotsContent = noindex
  ? 'noindex, follow'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'

const currentLocaleRoot = getRelativeLocaleUrl(locale, '')
const pathname = Astro.url.pathname
const pathWithinLocale = pathname.startsWith(currentLocaleRoot)
  ? pathname.slice(currentLocaleRoot.length)
  : pathname.replace(/^\/+/, '')

const canonicalURL = new URL(
  getAbsoluteLocaleUrl(canonicalLocale, pathWithinLocale)
)
canonicalURL.protocol = 'https:'

const alternateUrlEntries = Array.from(new Set(availableLocales)).map(
  (availableLocale) => {
    const hrefURL = new URL(
      getAbsoluteLocaleUrl(availableLocale, pathWithinLocale)
    )
    hrefURL.protocol = 'https:'

    return {
      locale: availableLocale,
      href: hrefURL.href,
    }
  }
)
const xDefaultURL = new URL(getAbsoluteLocaleUrl('zh', pathWithinLocale))
xDefaultURL.protocol = 'https:'

const generatedOgImage = checkFileExistsInDir(
  'public/og-images',
  `${basename(Astro.url.pathname)}.png`
)
  ? withBasePath('og-images', `${basename(Astro.url.pathname)}.png`)
  : undefined

const assignedOgImage =
  ogImage &&
  ogImage !== true &&
  checkFileExistsInDir('public/og-images', ogImage)
    ? withBasePath('og-images', ogImage)
    : undefined

const ogImageURL = new URL(
  assignedOgImage ||
    generatedOgImage ||
    withBasePath('og-images', 'og-image.png'),
  SITE.website
).href
const ogImageAlt = `${schemaName} - ${SITE.title}`
const sitemapURL = new URL(withBasePath('/sitemap-index.xml'), SITE.website)
  .href
const rssURL = new URL(
  withBasePath(isDefaultLocale(locale) ? '/rss.xml' : '/en/rss.xml'),
  SITE.website
).href
const rssTitle = isDefaultLocale(locale)
  ? `${SITE.title} RSS`
  : `${SITE.title} English RSS`
const siteRootURL = new URL(withBasePath('/'), SITE.website)
const websiteId = new URL(withBasePath('/#website'), SITE.website).href
const personId = new URL(withBasePath('/#person'), SITE.website).href
const pageId = `${canonicalURL.href}#webpage`
const imageId = `${canonicalURL.href}#primaryimage`
const breadcrumbId = `${canonicalURL.href}#breadcrumb`
const markdownURL = /^blog\/.+\/$/.test(pathWithinLocale)
  ? new URL('index.html.md', canonicalURL).href
  : undefined

const analyticsEnabled =
  import.meta.env.PROD && import.meta.env.PUBLIC_ENABLE_ANALYTICS !== 'false'
const umamiSrc = import.meta.env.PUBLIC_UMAMI_SRC
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID
const ahrefsKey = import.meta.env.PUBLIC_AHREFS_KEY
const enableUmami = analyticsEnabled && Boolean(umamiSrc && umamiWebsiteId)
const enableAhrefs = analyticsEnabled && Boolean(ahrefsKey)

const shareConfig = FEATURES.share
const twitterShare =
  Array.isArray(shareConfig) && shareConfig[0] ? shareConfig[1].twitter : false
const twitterHandle =
  Array.isArray(twitterShare) && twitterShare[0] ? twitterShare[1] : undefined
const twitterCreator = twitterHandle
  ? twitterHandle.startsWith('@')
    ? twitterHandle
    : `@${twitterHandle}`
  : undefined

function formatBreadcrumbName(segment: string) {
  try {
    return decodeURIComponent(segment).replace(/[-_]/g, ' ')
  } catch {
    return segment.replace(/[-_]/g, ' ')
  }
}

const breadcrumbSegments = pathWithinLocale.split('/').filter(Boolean)
const breadcrumbItems = [
  {
    '@type': 'ListItem',
    'position': 1,
    'name': SITE.title,
    'item': siteRootURL.href,
  },
  ...breadcrumbSegments.map((segment, index) => {
    const segmentPath = breadcrumbSegments.slice(0, index + 1).join('/')
    const itemURL = new URL(getAbsoluteLocaleUrl(canonicalLocale, segmentPath))
    itemURL.protocol = 'https:'

    return {
      '@type': 'ListItem',
      'position': index + 2,
      'name':
        index === breadcrumbSegments.length - 1
          ? schemaName
          : formatBreadcrumbName(segment),
      'item': itemURL.href,
    }
  }),
]

const breadcrumbData = breadcrumbSegments.length
  ? {
      '@type': 'BreadcrumbList',
      '@id': breadcrumbId,
      'itemListElement': breadcrumbItems,
    }
  : undefined

const personData = {
  '@type': 'Person',
  '@id': personId,
  'name': SITE.author,
  'url': siteRootURL.href,
  'sameAs': UI.socialLinks.map((item) => item.link),
}

const websiteData = {
  '@type': 'WebSite',
  '@id': websiteId,
  'url': siteRootURL.href,
  'name': SITE.title,
  'alternateName': ['Foo-Z', 'FOO-Z', SITE.author],
  'description': SITE.description,
  'inLanguage': localeToHtmlLang(canonicalLocale),
  'publisher': {
    '@id': personId,
  },
}

const imageData = {
  '@type': 'ImageObject',
  '@id': imageId,
  'url': ogImageURL,
  'contentUrl': ogImageURL,
  'width': 1200,
  'height': 630,
  'caption': ogImageAlt,
}

const pageData = pubDate
  ? {
      '@type': 'BlogPosting',
      '@id': `${canonicalURL.href}#blogposting`,
      'mainEntityOfPage': {
        '@id': pageId,
      },
      'headline': schemaName,
      'name': schemaName,
      'description': pageDescription,
      'url': canonicalURL.href,
      'image': {
        '@id': imageId,
      },
      'thumbnailUrl': ogImageURL,
      'datePublished': pubDate,
      'dateModified': lastModDate || pubDate,
      'author': {
        '@id': personId,
      },
      'publisher': {
        '@id': personId,
      },
      'isPartOf': {
        '@id': websiteId,
      },
      'inLanguage': localeToHtmlLang(canonicalLocale),
      ...(breadcrumbData && { breadcrumb: { '@id': breadcrumbId } }),
      ...(category && { articleSection: category }),
      ...(normalizedTags.length > 0 && { keywords: normalizedTags.join(', ') }),
    }
  : {
      '@type': 'WebPage',
      '@id': pageId,
      'url': canonicalURL.href,
      'name': schemaName,
      'description': pageDescription,
      'isPartOf': {
        '@id': websiteId,
      },
      'about': {
        '@id': personId,
      },
      'primaryImageOfPage': {
        '@id': imageId,
      },
      'image': {
        '@id': imageId,
      },
      'inLanguage': localeToHtmlLang(canonicalLocale),
      ...(breadcrumbData && { breadcrumb: { '@id': breadcrumbId } }),
    }

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    personData,
    websiteData,
    imageData,
    pageData,
    ...(breadcrumbData ? [breadcrumbData] : []),
  ],
}
const structuredDataJson = JSON.stringify(structuredData).replace(
  /</g,
  '\\u003c'
)
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<meta
  name="viewport"
  content="width=device-width, initial-scale=1.0, viewport-fit=cover"
/>
<meta name="generator" content={Astro.generator} />

<!-- Primary Metadata -->
<title>{pageTitle}</title>
<meta name="title" content={pageTitle} />
<meta name="description" content={pageDescription} />
<meta name="author" content={SITE.author} />
<meta name="robots" content={robotsContent} />

<!-- Color -->
<meta
  name="theme-color"
  media="(prefers-color-scheme: light)"
  content="#f2f4f6"
/>
<meta
  name="theme-color"
  media="(prefers-color-scheme: dark)"
  content="#050507"
/>
<meta name="color-scheme" content="light dark" />

<!-- Open Graph & Facebook -->
<meta property="og:type" content={pubDate ? 'article' : 'website'} />
<meta property="og:url" content={canonicalURL.href} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={pageDescription} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:secure_url" content={ogImageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:site_name" content={SITE.title} />
<meta property="og:locale" content={localeToOgLocale(canonicalLocale)} />
{
  alternateUrlEntries
    .filter(({ locale }) => locale !== canonicalLocale)
    .map(({ locale }) => (
      <meta property="og:locale:alternate" content={localeToOgLocale(locale)} />
    ))
}
{
  pubDate && (
    <>
      <meta property="article:author" content={SITE.author} />
      <meta property="article:published_time" content={pubDate} />
      {lastModDate && (
        <meta property="article:modified_time" content={lastModDate} />
      )}
      {category && <meta property="article:section" content={category} />}
      {normalizedTags.map((tag) => (
        <meta property="article:tag" content={tag} />
      ))}
    </>
  )
}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL.href} />
<meta property="twitter:title" content={pageTitle} />
<meta property="twitter:description" content={pageDescription} />
<meta property="twitter:image" content={ogImageURL} />
<meta property="twitter:image:alt" content={ogImageAlt} />
{
  twitterCreator && (
    <>
      <meta property="twitter:site" content={twitterCreator} />
      <meta property="twitter:creator" content={twitterCreator} />
    </>
  )
}

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL.href} />

<!-- hreflang -->
{
  alternateUrlEntries.map(({ locale, href }) => (
    <link rel="alternate" hreflang={localeToHtmlLang(locale)} href={href} />
  ))
}
<link rel="alternate" hreflang="x-default" href={xDefaultURL.href} />

<!-- 关键拉丁字体预加载（中文走系统栈；完整 @font-face 见 fonts.css） -->
<link
  rel="preload"
  href="https://fonts.bunny.net/ibm-plex-sans/files/ibm-plex-sans-latin-400-normal.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>
<link
  rel="preload"
  href="https://fonts.bunny.net/ibm-plex-sans/files/ibm-plex-sans-latin-600-normal.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>
<link rel="preconnect" href="https://fonts.bunny.net" crossorigin />

<!-- Icon -->
<link rel="icon" type="image/svg+xml" href={withBasePath('/favicon.svg')} />
<link rel="icon" sizes="32x32" href={withBasePath('/favicon.ico')} />
<link rel="apple-touch-icon" href={withBasePath('/apple-touch-icon.png')} />

<!-- Manifest -->
<link rel="manifest" href={withBasePath('/app.webmanifest')} />

<!-- Sitemap -->
<link rel="sitemap" type="application/xml" href={sitemapURL} />

<!-- RSS -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={rssTitle}
  href={rssURL}
/>

<!-- LLM-friendly article source -->
{
  markdownURL && (
    <link rel="alternate" type="text/markdown" href={markdownURL} />
  )
}

<!-- Google JSON-LD Structured Data -->
<script is:inline type="application/ld+json" set:html={structuredDataJson} />

{
  enableUmami && (
    <script is:inline defer src={umamiSrc} data-website-id={umamiWebsiteId} />
  )
}
{
  enableAhrefs && (
    <script
      is:inline
      async
      src="https://analytics.ahrefs.com/analytics.js"
      data-key={ahrefsKey}
    />
  )
}

<ClientRouter />
