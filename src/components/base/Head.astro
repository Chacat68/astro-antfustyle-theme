---
import { ClientRouter } from 'astro:transitions'
import { basename } from 'node:path'
import { getAbsoluteLocaleUrl, getRelativeLocaleUrl } from 'astro:i18n'

import { checkFileExistsInDir } from '../../../plugins/remark-generate-og-image'
import { withBasePath } from '~/utils/path'
import { SITE } from '~/config'
import { getLocale } from '~/i18n/translate'
import { localeToHtmlLang, localeToOgLocale } from '~/i18n/locale-meta'

import type { AppLocale } from '~/i18n/locales'

interface Props {
  title?: string
  description?: string
  ogImage?: string | boolean
  pubDate?: string
  lastModDate?: string
  availableLocales?: AppLocale[]
  canonicalLocale?: AppLocale
  noindex?: boolean
}

const {
  title,
  description,
  ogImage,
  pubDate,
  lastModDate,
  availableLocales = ['zh', 'en'],
  canonicalLocale: canonicalLocaleProp,
  noindex = false,
} = Astro.props

const locale = getLocale(Astro.currentLocale)
const canonicalLocale = getLocale(canonicalLocaleProp ?? locale)

const siteName = new URL(SITE.website).hostname

const pageTitle =
  title && title !== SITE.title
    ? `${title} - ${SITE.title}`
    : `${SITE.title} - ${SITE.description}`

const pageDescription = description || SITE.description

const currentLocaleRoot = getRelativeLocaleUrl(locale, '')
const pathname = Astro.url.pathname
const pathWithinLocale = pathname.startsWith(currentLocaleRoot)
  ? pathname.slice(currentLocaleRoot.length)
  : pathname.replace(/^\/+/, '')

const canonicalURL = new URL(
  getAbsoluteLocaleUrl(canonicalLocale, pathWithinLocale)
)
canonicalURL.protocol = 'https:'

const alternateUrlEntries = Array.from(new Set(availableLocales)).map(
  (locale) => ({
    locale,
    href: getAbsoluteLocaleUrl(locale, pathWithinLocale),
  })
)
const xDefaultUrl = getAbsoluteLocaleUrl('zh', pathWithinLocale)

const generatedOgImage = checkFileExistsInDir(
  'public/og-images',
  `${basename(Astro.url.pathname)}.png`
)
  ? withBasePath('og-images', `${basename(Astro.url.pathname)}.png`)
  : undefined

const assignedOgImage =
  ogImage &&
  ogImage !== true &&
  checkFileExistsInDir('public/og-images', ogImage)
    ? withBasePath('og-images', ogImage)
    : undefined

const ogImageURL = new URL(
  assignedOgImage ||
    generatedOgImage ||
    withBasePath('og-images', 'og-image.png'),
  Astro.url
).href

const enableAnalytics =
  import.meta.env.PROD && import.meta.env.PUBLIC_ENABLE_ANALYTICS !== 'false'
const umamiSrc =
  import.meta.env.PUBLIC_UMAMI_SRC || 'https://umami.chawfoo.com/script.js'
const umamiWebsiteId =
  import.meta.env.PUBLIC_UMAMI_WEBSITE_ID ||
  '729709c3-0b6c-4a94-8406-15016bd4472d'
const ahrefsKey = import.meta.env.PUBLIC_AHREFS_KEY || 'IHHLuVKFCFQS33iCD+EctA'

// https://jsonld.com/blog-post/
const blogPostingData = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  'mainEntityOfPage': {
    '@type': 'WebPage',
    '@id': canonicalURL.href,
  },
  'headline': pageTitle,
  'image': ogImageURL,
  'url': canonicalURL.href,
  'datePublished': pubDate,
  ...(lastModDate && { dateModified: lastModDate }),
  ...(description && { description: description }),
  'author': {
    '@type': 'Person',
    'name': SITE.author,
    'url': SITE.website,
  },
  'publisher': {
    '@type': 'Person',
    'name': SITE.author,
    'url': SITE.website,
  },
}

// https://jsonld.com/web-page/
const webPageData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  'name': `${title || SITE.title}`,
  'url': canonicalURL.href,
  ...(description && { description: description }),
  'publisher': {
    '@type': 'Person',
    'name': SITE.author,
    'url': SITE.website,
  },
}
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="generator" content={Astro.generator} />

<!-- Primary Metadata -->
<title>{pageTitle}</title>
<meta name="title" content={pageTitle} />
<meta name="description" content={pageDescription} />
<meta name="author" content={SITE.author} />
<meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />

<!-- Color -->
<meta name="theme-color" content="" />
<meta name="color-scheme" content="light dark" />

<!-- Open Graph & Facebook -->
<meta property="og:type" content={pubDate ? 'article' : 'website'} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={pageDescription} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content={localeToOgLocale(canonicalLocale)} />
{
  pubDate && (
    <>
      <meta property="article:author" content={SITE.author} />
      <meta property="article:published_time" content={pubDate} />
      <meta property="article:modified_time" content={lastModDate} />
    </>
  )
}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={pageTitle} />
<meta property="twitter:description" content={pageDescription} />
<meta property="twitter:image" content={ogImageURL} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- hreflang -->
{
  alternateUrlEntries.map(({ locale, href }) => (
    <link rel="alternate" hreflang={localeToHtmlLang(locale)} href={href} />
  ))
}
<link rel="alternate" hreflang="x-default" href={xDefaultUrl} />

<!-- Icon -->
<link rel="icon" type="image/svg+xml" href={withBasePath('/favicon.svg')} />
<link rel="icon" sizes="32x32" href={withBasePath('/favicon.ico')} />
<link rel="apple-touch-icon" href={withBasePath('/apple-touch-icon.png')} />

<!-- Manifest -->
<link rel="manifest" href={withBasePath('/app.webmanifest')} />

<!-- Sitemap -->
<link rel="sitemap" href={withBasePath('/sitemap-index.xml')} />

<!-- RSS -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={`${SITE.title} RSS`}
  href={withBasePath('/rss.xml')}
/>

<!-- Google JSON-LD Structured Data -->
{
  pubDate ? (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(blogPostingData)}
    />
  ) : (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(webPageData)}
    />
  )
}

{
  enableAnalytics && (
    <>
      <script is:inline defer src={umamiSrc} data-website-id={umamiWebsiteId} />
      <script
        is:inline
        async
        src="https://analytics.ahrefs.com/analytics.js"
        data-key={ahrefsKey}
      />
    </>
  )
}

<ClientRouter />
