---
import Link from '~/components/base/Link.astro'
import { ensureTrailingSlash } from '~/utils/path'
import { getLocale, useTranslations } from '~/i18n/translate'

const pathSegments = ensureTrailingSlash(Astro.url.pathname)
  .split('/')
  .slice(0, -2)
const href = pathSegments.length > 1 ? pathSegments.join('/') + '/' : '/'
const locale = getLocale(Astro.currentLocale)
const t = useTranslations(locale)
---

<span class="font-mono op-50">&gt; </span>
<Link class="font-mono op-50!" {href}>{t('footer.back')}</Link>
