---
import { getLocalizedBlogPosts, getSortedPosts } from '~/utils/data'
import { formatDate } from '~/utils/datetime'
import { ensureTrailingSlash } from '~/utils/path'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { getLocale, useTranslations } from '~/i18n/translate'
import { localeToHtmlLang } from '~/i18n/locale-meta'

interface Props {
  limit?: number
}

const { limit = 6 } = Astro.props

const locale = getLocale(Astro.currentLocale)
const t = useTranslations(locale)
const dateLocale = localeToHtmlLang(locale)
const toPostHref = (id: string) =>
  ensureTrailingSlash(getRelativeLocaleUrl(locale, `blog/${id}`))

// 获取最新的博客文章
const allPosts = await getLocalizedBlogPosts(Astro.currentLocale)
const sortedPosts = getSortedPosts(allPosts)
const latestPosts = sortedPosts.slice(0, limit)
---

<section class="latest-posts" aria-labelledby="latest-posts-heading">
  <div class="latest-posts__header">
    <span class="hud-label" aria-hidden="true">// BLOG_FEED</span>
    <h2 id="latest-posts-heading">{t('widget.latestPosts')}</h2>
  </div>
  <ol class="latest-post-list">
    {
      latestPosts.map((post) => (
        <li class="latest-post-item">
          <a class="latest-post-link hud-frame" href={toPostHref(post.id)}>
            <span class="hud-corner hud-corner--tl" aria-hidden="true" />
            <span class="hud-corner hud-corner--br" aria-hidden="true" />
            <span class="latest-post-meta font-mono">
              <time datetime={post.data.pubDate?.toISOString()}>
                {post.data.pubDate &&
                  formatDate(post.data.pubDate, false, false, dateLocale)}
              </time>
              {post.data.category && (
                <span class="latest-post-category">{post.data.category}</span>
              )}
            </span>
            <span class="latest-post-title">{post.data.title}</span>
            {post.data.description && (
              <span class="latest-post-description">
                {post.data.description}
              </span>
            )}
          </a>
        </li>
      ))
    }
  </ol>
</section>

<style>
  .latest-posts {
    margin-block: 2.25rem 2rem;
  }

  .latest-posts__header {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 0.85rem;
  }

  .latest-posts__header .hud-label {
    opacity: 0.7;
  }

  .latest-posts__header h2 {
    margin: 0 !important;
  }

  .latest-post-list {
    display: grid;
    gap: 0.75rem;

    list-style: none;
    padding: 0;
    margin: 0;
  }

  .latest-post-item {
    padding-left: 0;
    margin: 0;
  }

  .latest-post-item::before {
    content: none;
  }

  .latest-post-link {
    display: grid;
    gap: 0.35rem;

    padding: 0.9rem 1rem;
    border-radius: var(--c-radius) !important;

    color: inherit;
    opacity: 1 !important;
    text-decoration: none;

    transition:
      background var(--duration, 200ms) var(--ease-out, ease),
      border-color var(--duration, 200ms) var(--ease-out, ease),
      box-shadow var(--duration, 200ms) var(--ease-out, ease),
      transform var(--duration, 200ms) var(--ease-out, ease);
  }

  .latest-post-link:hover,
  .latest-post-link:focus-visible {
    border-color: color-mix(
      in srgb,
      var(--c-accent) 40%,
      var(--c-border)
    ) !important;
    background: color-mix(in srgb, var(--c-surface) 78%, var(--c-accent-soft));
    box-shadow: var(--c-shadow-hover);
    transform: translateY(-2px);
  }

  .latest-post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;

    color: var(--c-muted);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    line-height: 1.4;
  }

  .latest-post-category {
    color: var(--c-accent);
    font-weight: 600;
  }

  .latest-post-category::before {
    content: '/';
    margin-right: 0.45rem;
    color: var(--c-muted);
    font-weight: 400;
  }

  .latest-post-title {
    color: var(--fg-deeper);
    font-size: 1.03rem;
    font-weight: 600;
    line-height: 1.45;
  }

  .latest-post-description {
    display: -webkit-box;
    overflow: hidden;

    color: var(--fg);
    font-size: 0.92rem;
    line-height: 1.65;

    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .latest-post-link .hud-corner {
    width: 0.45rem;
    height: 0.45rem;
    opacity: 0.7;
  }

  .latest-post-link .hud-corner--tl {
    top: 0.25rem;
    left: 0.25rem;
  }

  .latest-post-link .hud-corner--br {
    right: 0.25rem;
    bottom: 0.25rem;
  }

  @media (max-width: 767.9px) {
    .latest-post-link {
      padding: 0.82rem 0.85rem;
    }
  }
</style>
