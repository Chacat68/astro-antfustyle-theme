---
/**
 * 导航左上角故障艺术 Logo
 * 视觉对齐首页展示台：方框 + X + 底杠，字标 RGB 微错位
 */
import Link from '~/components/base/Link.astro'
import { ensureTrailingSlash } from '~/utils/path'
import { SITE } from '~/config'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { getLocale } from '~/i18n/translate'

const locale = getLocale(Astro.currentLocale)
const homeHref = ensureTrailingSlash(getRelativeLocaleUrl(locale, ''))
const word = SITE.title
---

<Link
  class="logo-link select-none op-100! hover:op-100"
  href={homeHref}
  aria-label={SITE.author}
  aria-current={ensureTrailingSlash(Astro.url.pathname) === homeHref
    ? 'page'
    : false}
>
  <span class="logo">
    <span class="logo-mark" aria-hidden="true">
      <span class="logo-mark__x"></span>
      <span class="logo-mark__bar"></span>
      <span class="logo-mark__scan"></span>
    </span>
    <span class="logo-word" data-text={word}>{word}</span>
  </span>
</Link>

<style>
  .logo {
    --logo-red: var(--c-glitch-red, #ff2a4a);
    --logo-cyan: var(--c-glitch-cyan, #2ad4ff);

    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
  }

  /* —— 方框角标（呼应首页中央舞台） —— */
  .logo-mark {
    position: relative;
    display: block;
    flex: 0 0 1.45rem;
    width: 1.45rem;
    height: 1.45rem;
    border: 1px solid color-mix(in srgb, var(--c-text) 72%, transparent);
    background: color-mix(in srgb, var(--c-bg) 40%, transparent);
    overflow: hidden;
    box-shadow:
      -1px 0 0 color-mix(in srgb, var(--logo-red) 45%, transparent),
      1px 0 0 color-mix(in srgb, var(--logo-cyan) 45%, transparent);
  }

  .logo-mark::before,
  .logo-mark::after {
    content: '';
    position: absolute;
    width: 0.32rem;
    height: 0.32rem;
    border-color: var(--c-accent);
    border-style: solid;
    z-index: 2;
  }

  .logo-mark::before {
    top: -1px;
    left: -1px;
    border-width: 1.5px 0 0 1.5px;
  }

  .logo-mark::after {
    right: -1px;
    bottom: -1px;
    border-width: 0 1.5px 1.5px 0;
  }

  .logo-mark__x::before,
  .logo-mark__x::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 16%;
    width: 1.5px;
    height: 68%;
    background: color-mix(in srgb, var(--c-text) 48%, transparent);
  }

  .logo-mark__x::before {
    transform: translateX(-50%) rotate(45deg);
  }

  .logo-mark__x::after {
    transform: translateX(-50%) rotate(-45deg);
  }

  .logo-mark__bar {
    position: absolute;
    left: 22%;
    right: 22%;
    bottom: 22%;
    height: 2px;
    background: var(--c-text);
    box-shadow:
      -1px 0 0 var(--logo-red),
      1px 0 0 var(--logo-cyan);
    z-index: 1;
  }

  .logo-mark__scan {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      transparent 0%,
      color-mix(in srgb, var(--c-accent) 28%, transparent) 50%,
      transparent 100%
    );
    transform: translateY(-100%);
    animation: logo-scan 3.6s linear infinite;
    pointer-events: none;
  }

  /* —— 字标 —— */
  .logo-word {
    position: relative;
    display: block;
    flex: 0 0 auto;
    font-size: 1.12rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.12em;
    white-space: nowrap;
    color: var(--c-text);
  }

  .logo-word::before,
  .logo-word::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transition: opacity 160ms var(--ease-out, ease);
  }

  .logo-word::before {
    color: var(--logo-red);
    transform: translate(-1.5px, 0);
    clip-path: inset(0 0 52% 0);
  }

  .logo-word::after {
    color: var(--logo-cyan);
    transform: translate(1.5px, 0);
    clip-path: inset(48% 0 0 0);
  }

  /* hover / focus / 当前页 */
  .logo-link:hover .logo-mark,
  .logo-link:focus-visible .logo-mark,
  .logo-link[aria-current='page'] .logo-mark {
    border-color: color-mix(in srgb, var(--c-text) 88%, transparent);
    background: color-mix(in srgb, var(--c-accent) 10%, transparent);
  }

  .logo-link:hover .logo-mark__bar,
  .logo-link:focus-visible .logo-mark__bar,
  .logo-link[aria-current='page'] .logo-mark__bar {
    background: var(--c-accent);
  }

  .logo-link:hover .logo-word,
  .logo-link:focus-visible .logo-word,
  .logo-link[aria-current='page'] .logo-word {
    color: var(--c-accent);
  }

  .logo-link:hover .logo-word::before,
  .logo-link:hover .logo-word::after,
  .logo-link:focus-visible .logo-word::before,
  .logo-link:focus-visible .logo-word::after,
  .logo-link[aria-current='page'] .logo-word::before,
  .logo-link[aria-current='page'] .logo-word::after {
    opacity: 0.85;
  }

  .logo-link:hover .logo-mark__scan,
  .logo-link:focus-visible .logo-mark__scan {
    animation-duration: 1.4s;
  }

  .logo-link:focus-visible {
    outline: 1px solid color-mix(in srgb, var(--c-accent) 70%, transparent);
    outline-offset: 4px;
  }

  @keyframes logo-scan {
    0% {
      transform: translateY(-110%);
    }
    100% {
      transform: translateY(110%);
    }
  }

  @media (max-width: 767.9px) {
    .logo {
      gap: 0.5rem;
    }

    .logo-mark {
      flex-basis: 1.25rem;
      width: 1.25rem;
      height: 1.25rem;
    }

    .logo-word {
      font-size: 0.95rem;
      letter-spacing: 0.1em;
    }
  }

  /* 极窄屏只留方框标，给右侧工具按钮腾位 */
  @media (max-width: 379.9px) {
    .logo-word {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-mark__scan {
      animation: none;
      opacity: 0.15;
      transform: none;
    }

    .logo-word::before,
    .logo-word::after {
      transition: none;
    }
  }
</style>
