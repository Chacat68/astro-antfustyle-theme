---
import { getLocale, useTranslations } from '~/i18n/translate'

interface Props {
  title: string
}

const { title } = Astro.props
const locale = getLocale(Astro.currentLocale)
const t = useTranslations(locale)

const roles = [
  t('home.role.game'),
  t('home.role.creator'),
  t('home.role.photo'),
  t('home.role.code'),
] as const
---

<section class="about-screen slide-enter-instant" aria-labelledby="about-screen-title">
  <div class="about-screen__frame">
    <span class="about-screen__corner about-screen__corner--tl" aria-hidden="true"></span>
    <span class="about-screen__corner about-screen__corner--tr" aria-hidden="true"></span>
    <span class="about-screen__corner about-screen__corner--bl" aria-hidden="true"></span>
    <span class="about-screen__corner about-screen__corner--br" aria-hidden="true"></span>

    <div class="about-screen__scanlines" aria-hidden="true"></div>
    <div class="about-screen__sweep" aria-hidden="true"></div>

    <header class="about-screen__chrome">
      <div class="about-screen__chrome-left">
        <span class="about-screen__led" aria-hidden="true"></span>
        <span class="about-screen__tag font-mono">{t('home.screen.tag')}</span>
      </div>
      <span class="about-screen__status font-mono">
        <span class="about-screen__status-dot" aria-hidden="true"></span>
        {t('home.screen.status')}
      </span>
    </header>

    <div class="about-screen__body">
      {/* 可见标题隐藏；保留 h1 供无障碍与文档标题「首页」 */}
      <h1 id="about-screen-title" class="about-screen__title sr-only">
        {title}
      </h1>

      <p class="about-screen__intro">{t('home.intro1')}</p>
      <p class="about-screen__intro">{t('home.intro2')}</p>

      <div class="about-screen__modules">
        <div class="about-screen__modules-label font-mono">
          {t('home.screen.modules')}
        </div>
        <ul class="about-screen__module-list">
          {
            roles.map((role) => (
              <li>
                <span class="about-screen__module">
                  <span class="about-screen__module-mark" aria-hidden="true" />
                  <span class="about-screen__module-text">{role}</span>
                </span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <footer class="about-screen__footer font-mono" aria-hidden="true">
      <span>{t('home.screen.coords')}</span>
      <span class="about-screen__footer-sep">//</span>
      <span>{t('home.screen.signal')}</span>
    </footer>
  </div>
</section>

<style>
  .about-screen {
    --about-glow: color-mix(in srgb, var(--c-accent) 35%, transparent);
    --about-line: color-mix(in srgb, var(--c-accent) 55%, transparent);
    --about-panel: color-mix(in srgb, var(--c-surface) 88%, var(--c-accent-soft));
    --about-scan: 4.5%;
    --about-grid: 3%;

    margin-block: 0 1.75rem;
  }

  :global(:root.dark) .about-screen {
    --about-glow: color-mix(in srgb, var(--c-accent) 55%, transparent);
    --about-panel: color-mix(in srgb, #0b1016 82%, var(--c-accent-soft));
    --about-scan: 8%;
    --about-grid: 6%;
  }

  .about-screen__frame {
    position: relative;
    overflow: hidden;
    padding: 1rem 1.15rem 0.85rem;

    border: 1px solid color-mix(in srgb, var(--c-accent) 28%, var(--c-border));
    border-radius: var(--c-radius-lg);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--c-accent) 6%, transparent),
        transparent 42%
      ),
      linear-gradient(
        color-mix(in srgb, var(--c-accent) var(--about-grid), transparent) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--c-accent) var(--about-grid), transparent) 1px,
        transparent 1px
      ),
      var(--about-panel);
    background-size:
      auto,
      22px 22px,
      22px 22px,
      auto;
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--c-accent) 10%, transparent) inset,
      0 0 24px color-mix(in srgb, var(--c-accent) 12%, transparent),
      var(--c-shadow);
  }

  :global(:root.dark) .about-screen__frame {
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--c-accent) 16%, transparent) inset,
      0 0 28px color-mix(in srgb, var(--c-accent) 22%, transparent),
      0 12px 40px rgba(0, 0, 0, 0.45);
  }

  .about-screen__corner {
    position: absolute;
    z-index: 3;
    width: 0.7rem;
    height: 0.7rem;
    border-color: var(--c-accent);
    border-style: solid;
    pointer-events: none;
  }

  .about-screen__corner--tl {
    top: 0.35rem;
    left: 0.35rem;
    border-width: 1.5px 0 0 1.5px;
  }

  .about-screen__corner--tr {
    top: 0.35rem;
    right: 0.35rem;
    border-width: 1.5px 1.5px 0 0;
  }

  .about-screen__corner--bl {
    bottom: 0.35rem;
    left: 0.35rem;
    border-width: 0 0 1.5px 1.5px;
  }

  .about-screen__corner--br {
    right: 0.35rem;
    bottom: 0.35rem;
    border-width: 0 1.5px 1.5px 0;
  }

  .about-screen__scanlines {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 2px,
      color-mix(in srgb, var(--c-accent) var(--about-scan), transparent) 2px,
      color-mix(in srgb, var(--c-accent) var(--about-scan), transparent) 3px
    );
    opacity: 0.55;
    mix-blend-mode: soft-light;
  }

  :global(:root.dark) .about-screen__scanlines {
    opacity: 0.72;
    mix-blend-mode: screen;
  }

  .about-screen__sweep {
    position: absolute;
    z-index: 2;
    top: -30%;
    left: 0;
    width: 100%;
    height: 28%;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      transparent,
      color-mix(in srgb, var(--c-accent) 14%, transparent),
      transparent
    );
    will-change: transform;
    animation: about-screen-sweep 4.8s linear infinite;
  }

  .about-screen__chrome,
  .about-screen__body,
  .about-screen__footer {
    position: relative;
    z-index: 1;
  }

  .about-screen__chrome {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.95rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid color-mix(in srgb, var(--c-accent) 22%, var(--c-border));
  }

  .about-screen__chrome-left {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-width: 0;
  }

  .about-screen__led {
    flex-shrink: 0;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--c-accent);
    box-shadow: 0 0 8px var(--about-glow);
    animation: about-screen-blink 1.8s steps(1, end) infinite;
  }

  .about-screen__tag,
  .about-screen__status,
  .about-screen__modules-label,
  .about-screen__footer {
    color: color-mix(in srgb, var(--c-accent) 78%, var(--c-muted));
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .about-screen__tag {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .about-screen__status {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    gap: 0.35rem;
  }

  .about-screen__status-dot {
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: var(--c-accent);
    box-shadow: 0 0 6px var(--about-glow);
    animation: about-screen-blink 1.2s steps(1, end) infinite;
  }

  .about-screen__title {
    margin: 0 0 0.95rem !important;
    color: var(--fg-deeper);
    font-size: 1.85em;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-shadow: 0 0 18px color-mix(in srgb, var(--c-accent) 18%, transparent);
  }

  .about-screen__intro {
    margin: 0 0 0.9rem !important;
    color: var(--fg-deep);
    font-size: 1.02em;
    line-height: 1.75;
  }

  .about-screen__intro:last-of-type {
    margin-bottom: 1.2rem !important;
  }

  .about-screen__modules {
    padding: 1.15rem 1.25rem 1.2rem;
    border: 1px solid color-mix(in srgb, var(--c-accent) 24%, var(--c-border));
    border-radius: var(--c-radius);
    background: color-mix(in srgb, var(--c-bg) 55%, transparent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--c-accent) 6%, transparent) inset;
  }

  .about-screen__modules-label {
    margin-bottom: 0.85rem;
    opacity: 0.85;
  }

  .about-screen__module-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin: 0 !important;
    padding: 0 !important;
    list-style: none !important;
  }

  .about-screen__module-list > li {
    margin: 0 !important;
    padding: 0 !important;
  }

  .about-screen__module-list > li::before {
    content: none !important;
    display: none !important;
  }

  .about-screen__module {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.6rem 1.5rem 0.6rem 1rem;
    border: 1px solid color-mix(in srgb, var(--c-accent) 30%, var(--c-border));
    border-radius: var(--c-radius-sm);
    background: color-mix(in srgb, var(--c-accent) 7%, var(--c-surface));
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out);
  }

  .about-screen__module:hover {
    border-color: color-mix(in srgb, var(--c-accent) 55%, var(--c-border));
    background: color-mix(in srgb, var(--c-accent) 12%, var(--c-surface));
    box-shadow: 0 0 12px color-mix(in srgb, var(--c-accent) 16%, transparent);
  }

  .about-screen__module-mark {
    flex-shrink: 0;
    width: 0.28rem;
    height: 0.28rem;
    border-radius: 1px;
    background: var(--c-accent);
    box-shadow: 0 0 6px var(--about-glow);
  }

  .about-screen__module-text {
    color: var(--fg-deeper);
    font-size: 0.92em;
    font-weight: 600;
    letter-spacing: 0.01em;
    line-height: 1.3;
  }

  .about-screen__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: 0.85rem;
    padding-top: 0.55rem;
    border-top: 1px dashed color-mix(in srgb, var(--c-accent) 20%, var(--c-border));
    opacity: 0.72;
  }

  .about-screen__footer-sep {
    opacity: 0.45;
  }

  @keyframes about-screen-sweep {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(460%);
    }
  }

  @keyframes about-screen-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.2;
    }
  }

  @media (max-width: 639.9px) {
    .about-screen__frame {
      padding: 0.9rem 0.85rem 0.75rem;
    }

    .about-screen__title {
      font-size: 1.55em;
    }

    .about-screen__module {
      display: flex;
      width: 100%;
    }

    .about-screen__footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.2rem;
    }

    .about-screen__footer-sep {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .about-screen__sweep,
    .about-screen__led,
    .about-screen__status-dot {
      animation: none;
    }

    .about-screen__sweep {
      will-change: auto;
      opacity: 0;
    }

    .about-screen__led,
    .about-screen__status-dot {
      opacity: 1;
    }
  }
</style>
