---
import { getLocale, useTranslations } from '~/i18n/translate'
import { getLocalizedBlogPosts } from '~/utils/data'

const locale = getLocale(Astro.currentLocale)
const t = useTranslations(locale)

const posts = await getLocalizedBlogPosts(Astro.currentLocale)
const now = new Date()

const postDates = posts
  .map((post) => post.data.pubDate || post.data.published)
  .filter((d): d is Date => d instanceof Date)

const startDate = postDates.length
  ? new Date(Math.min(...postDates.map((d) => d.valueOf())))
  : now

function formatYMD(date: Date) {
  return date.toISOString().split('T')[0]
}

function getDurationParts(from: Date, to: Date) {
  let years = to.getFullYear() - from.getFullYear()
  let months = to.getMonth() - from.getMonth()
  let days = to.getDate() - from.getDate()

  if (days < 0) {
    const lastMonth = new Date(to.getFullYear(), to.getMonth(), 0)
    days += lastMonth.getDate()
    months -= 1
  }

  if (months < 0) {
    months += 12
    years -= 1
  }

  return {
    years: Math.max(0, years),
    months: Math.max(0, months),
    days: Math.max(0, days),
  }
}

const durationParts = getDurationParts(startDate, now)
const daysOperating = Math.max(
  0,
  Math.floor((now.valueOf() - startDate.valueOf()) / 86400000) + 1
)

function countChars(text: string) {
  const cjk = text.match(/[\u4e00-\u9fff]/g)?.length ?? 0
  const latinWords = text.match(/[A-Za-z0-9]+(?:'[A-Za-z0-9]+)?/g)?.length ?? 0
  return cjk + latinWords
}

let totalWordCount = 0
for (const post of posts) {
  totalWordCount += countChars(post.body ?? '')
}

const yearCountMap = new Map<number, number>()
for (const post of posts) {
  const pubDate = post.data.pubDate || post.data.published
  if (!pubDate) continue
  const y = pubDate.getFullYear()
  yearCountMap.set(y, (yearCountMap.get(y) ?? 0) + 1)
}

const yearCounts = Array.from(yearCountMap.entries())
  .sort((a, b) => b[0] - a[0])
  .map(([year, count]) => ({ year, count }))

const maxYearCount = Math.max(1, ...yearCounts.map((item) => item.count))
const postCount = posts.length
const startYmd = formatYMD(startDate)

function formatWordCount(count: number, loc: string) {
  const formatted = count.toLocaleString()
  if (loc === 'zh' && count >= 10000) {
    const wan = (count / 10000).toFixed(1)
    return `${formatted}（${wan}万字）`
  }
  if (loc === 'en' && count >= 1000) {
    const k = (count / 1000).toFixed(1)
    return `${formatted} (${k}k)`
  }
  return formatted
}

function formatWordCountPrimary(count: number, loc: string) {
  if (loc === 'zh' && count >= 10000) {
    return (count / 10000).toFixed(1)
  }
  if (loc === 'en' && count >= 1000) {
    return (count / 1000).toFixed(1)
  }
  return count.toLocaleString()
}

function formatWordCountUnit(count: number, loc: string) {
  if (loc === 'zh' && count >= 10000) return '万字'
  if (loc === 'en' && count >= 1000) return 'k'
  return ''
}

const wordPrimary = formatWordCountPrimary(totalWordCount, locale)
const wordUnit = formatWordCountUnit(totalWordCount, locale)
const wordExact = totalWordCount.toLocaleString()
---

<section class="site-stats" aria-labelledby="site-stats-title">
  <div class="site-stats__frame hud-frame">
    <span class="hud-corner hud-corner--tl" aria-hidden="true"></span>
    <span class="hud-corner hud-corner--tr" aria-hidden="true"></span>
    <span class="hud-corner hud-corner--bl" aria-hidden="true"></span>
    <span class="hud-corner hud-corner--br" aria-hidden="true"></span>
    <div class="hud-scanlines site-stats__scanlines" aria-hidden="true"></div>

    <header class="site-stats__chrome">
      <div class="site-stats__chrome-left">
        <span class="hud-led" aria-hidden="true"></span>
        <span class="hud-label site-stats__tag">{t('sitestats.tag')}</span>
      </div>
      <span class="hud-status site-stats__status">
        <span class="hud-led hud-led--sm" aria-hidden="true"></span>
        {
          t('sitestats.status', {
            count: postCount,
          })
        }
      </span>
    </header>

    <div class="site-stats__body">
      <h3 id="site-stats-title" class="site-stats__title">
        {t('sitestats.title')}
      </h3>

      <div class="site-stats__metrics">
        <article class="stat-module">
          <p class="stat-module__key">{t('sitestats.operatingTime')}</p>
          <p class="stat-module__value">
            <span class="stat-module__num font-mono">
              {daysOperating.toLocaleString()}
            </span>
            <span class="stat-module__unit">{t('sitestats.daysUnit')}</span>
          </p>
          <p class="stat-module__detail font-mono">
            {t('sitestats.sinceStart', { start: startYmd })}
          </p>
          <p class="stat-module__sub">
            {
              t('sitestats.operatingTimeSub', {
                years: durationParts.years,
                months: durationParts.months,
                days: durationParts.days,
              })
            }
          </p>
        </article>

        <article class="stat-module">
          <p class="stat-module__key">{t('sitestats.totalWords')}</p>
          <p class="stat-module__value">
            <span class="stat-module__num font-mono">{wordPrimary}</span>
            {
              wordUnit ? (
                <span class="stat-module__unit">{wordUnit}</span>
              ) : null
            }
          </p>
          {
            wordUnit ? (
              <p
                class="stat-module__detail font-mono"
                title={formatWordCount(totalWordCount, locale)}
              >
                {wordExact}
              </p>
            ) : null
          }
        </article>
      </div>

      <div class="site-stats__years">
        <p class="hud-label site-stats__years-label">
          {t('sitestats.postsPerYear')}
        </p>
        {
          yearCounts.length ? (
            <ul class="year-bars">
              {yearCounts.map((item, index) => {
                const ratio = Math.round((item.count / maxYearCount) * 100)
                return (
                  <li
                    class="year-bar"
                    style={`--bar-ratio: ${ratio}%; --bar-delay: ${index * 60}ms`}
                  >
                    <span class="year-bar__year font-mono">{item.year}</span>
                    <span class="year-bar__track" aria-hidden="true">
                      <span class="year-bar__fill" />
                    </span>
                    <span class="year-bar__count font-mono">
                      {t('sitestats.yearItemCount', { count: item.count })}
                    </span>
                  </li>
                )
              })}
            </ul>
          ) : (
            <p class="site-stats__empty">{t('sitestats.noData')}</p>
          )
        }
      </div>
    </div>

    <footer class="hud-label site-stats__footer" aria-hidden="true">
      <span>{t('sitestats.footerSrc')}</span>
      <span class="site-stats__footer-sep">//</span>
      <span>{t('sitestats.footerSince', { start: startYmd })}</span>
    </footer>
  </div>
</section>

<style>
  .site-stats {
    --stats-panel: color-mix(in srgb, var(--c-surface) 88%, var(--c-accent-soft));
    --stats-fill: color-mix(in srgb, var(--c-accent) 72%, transparent);
    --stats-grid: 3%;

    margin: 1.75rem 0 2.25rem;
  }

  :global(:root.dark) .site-stats {
    --stats-panel: color-mix(in srgb, var(--c-surface) 82%, var(--c-accent-soft));
    --stats-fill: color-mix(in srgb, var(--c-accent) 58%, transparent);
    --stats-grid: 5%;
  }

  .site-stats__frame {
    padding: 1rem 1.15rem 0.85rem;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--c-accent) 6%, transparent),
        transparent 42%
      ),
      linear-gradient(
        color-mix(in srgb, var(--c-accent) var(--stats-grid), transparent) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--c-accent) var(--stats-grid), transparent) 1px,
        transparent 1px
      ),
      var(--stats-panel);
    background-size:
      auto,
      22px 22px,
      22px 22px,
      auto;
  }

  :global(:root.dark) .site-stats__frame {
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--c-accent) 16%, transparent) inset,
      0 0 24px color-mix(in srgb, var(--c-glow, var(--c-accent)) 28%, transparent),
      var(--c-shadow);
  }

  .site-stats__scanlines {
    opacity: 0.4;
  }

  :global(:root.dark) .site-stats__scanlines {
    opacity: 0.55;
  }

  .site-stats__chrome,
  .site-stats__body,
  .site-stats__footer {
    position: relative;
    z-index: 1;
  }

  .site-stats__chrome {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.9rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid color-mix(in srgb, var(--c-accent) 22%, var(--c-border));
  }

  .site-stats__chrome-left {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-width: 0;
  }

  .site-stats__tag {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .site-stats__status {
    flex-shrink: 0;
  }

  .site-stats__title {
    margin: 0 0 0.95rem !important;
    color: var(--fg-deeper, var(--c-text));
    font-size: 1.05rem !important;
    font-weight: 600;
    letter-spacing: 0.04em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .site-stats__metrics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem;
    margin-bottom: 1.1rem;
  }

  .stat-module {
    padding: 0.85rem 0.95rem;
    border: 1px solid color-mix(in srgb, var(--c-accent) 24%, var(--c-border));
    border-radius: var(--c-radius);
    background: color-mix(in srgb, var(--c-bg) 55%, transparent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--c-accent) 6%, transparent) inset;
    transition:
      border-color var(--duration-fast, 150ms) var(--ease-out),
      background var(--duration-fast, 150ms) var(--ease-out),
      box-shadow var(--duration-fast, 150ms) var(--ease-out);
  }

  .stat-module:hover {
    border-color: color-mix(in srgb, var(--c-accent) 48%, var(--c-border));
    background: color-mix(in srgb, var(--c-accent) 10%, var(--c-surface));
    box-shadow: 0 0 12px color-mix(in srgb, var(--c-accent) 14%, transparent);
  }

  .stat-module__key {
    margin: 0 0 0.55rem !important;
    color: var(--c-muted);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
  }

  .stat-module__value {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    margin: 0 !important;
    line-height: 1.1;
  }

  .stat-module__num {
    color: var(--fg-deeper, var(--c-text));
    font-size: clamp(1.5rem, 3.1vw, 1.85rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
  }

  .stat-module__unit {
    color: var(--c-accent);
    font-size: 0.88rem;
    font-weight: 600;
  }

  .stat-module__detail,
  .stat-module__sub {
    margin: 0.4rem 0 0 !important;
    color: var(--c-muted);
    font-size: 0.78rem;
    line-height: 1.45;
    letter-spacing: 0.03em;
  }

  .stat-module__sub {
    opacity: 0.88;
  }

  .site-stats__years-label {
    margin: 0 0 0.65rem !important;
    opacity: 0.78;
  }

  .year-bars {
    display: grid;
    gap: 0.5rem;
    margin: 0 !important;
    padding: 0 !important;
    list-style: none;
  }

  .year-bar {
    display: grid;
    grid-template-columns: 3.25rem 1fr auto;
    gap: 0.65rem;
    align-items: center;
    margin: 0 !important;
    padding: 0 !important;
  }

  .year-bar::before {
    content: none !important;
    display: none !important;
  }

  .year-bar__year {
    color: var(--fg-deeper, var(--c-text));
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    font-variant-numeric: tabular-nums;
  }

  .year-bar__track {
    position: relative;
    overflow: hidden;
    height: 0.38rem;
    border: 1px solid color-mix(in srgb, var(--c-accent) 22%, var(--c-border));
    border-radius: 1px;
    background: color-mix(in srgb, var(--c-border) 70%, transparent);
  }

  .year-bar__fill {
    display: block;
    width: var(--bar-ratio);
    height: 100%;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--c-accent) 45%, transparent),
      var(--stats-fill)
    );
    box-shadow: 0 0 8px color-mix(in srgb, var(--c-accent) 28%, transparent);
    transform-origin: left center;
    animation: stats-bar-in 520ms var(--ease-out) both;
    animation-delay: var(--bar-delay, 0ms);
  }

  .year-bar__count {
    min-width: 3.5rem;
    color: var(--c-muted);
    font-size: 0.78rem;
    letter-spacing: 0.03em;
    text-align: right;
    white-space: nowrap;
  }

  .site-stats__empty {
    margin: 0.35rem 0 0 !important;
    color: var(--c-muted);
    font-size: 0.88rem;
  }

  .site-stats__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: 0.95rem;
    padding-top: 0.55rem;
    border-top: 1px dashed color-mix(in srgb, var(--c-accent) 20%, var(--c-border));
    opacity: 0.72;
  }

  .site-stats__footer-sep {
    opacity: 0.45;
  }

  @keyframes stats-bar-in {
    from {
      transform: scaleX(0);
      opacity: 0.35;
    }
    to {
      transform: scaleX(1);
      opacity: 1;
    }
  }

  @media (max-width: 640px) {
    .site-stats__frame {
      padding: 0.9rem 0.85rem 0.75rem;
    }

    .site-stats__metrics {
      grid-template-columns: 1fr;
    }

    .site-stats__chrome {
      flex-wrap: wrap;
    }

    .year-bar {
      grid-template-columns: 2.75rem 1fr auto;
      gap: 0.5rem;
    }

    .year-bar__count {
      min-width: 3rem;
    }

    .site-stats__footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.2rem;
    }

    .site-stats__footer-sep {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .stat-module {
      transition: none;
    }

    .year-bar__fill {
      animation: none;
    }
  }
</style>
