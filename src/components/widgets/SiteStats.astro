---
import { getLocale, useTranslations } from '~/i18n/translate'
import { getLocalizedBlogPosts } from '~/utils/data'

const locale = getLocale(Astro.currentLocale)
const t = useTranslations(locale)

// Blog posts
const posts = await getLocalizedBlogPosts(Astro.currentLocale)

const now = new Date()

const postDates = posts
  .map((post) => post.data.pubDate || post.data.published)
  .filter((d): d is Date => d instanceof Date)

const startDate = postDates.length
  ? new Date(Math.min(...postDates.map((d) => d.valueOf())))
  : now

function formatYMD(date: Date) {
  return date.toISOString().split('T')[0]
}

function getDurationParts(from: Date, to: Date) {
  let years = to.getFullYear() - from.getFullYear()
  let months = to.getMonth() - from.getMonth()
  let days = to.getDate() - from.getDate()

  if (days < 0) {
    const lastMonth = new Date(to.getFullYear(), to.getMonth(), 0)
    days += lastMonth.getDate()
    months -= 1
  }

  if (months < 0) {
    months += 12
    years -= 1
  }

  return {
    years: Math.max(0, years),
    months: Math.max(0, months),
    days: Math.max(0, days),
  }
}

const durationParts = getDurationParts(startDate, now)
const daysOperating = Math.max(
  0,
  Math.floor((now.valueOf() - startDate.valueOf()) / 86400000) + 1
)

function countChars(text: string) {
  const cjk = text.match(/[\u4e00-\u9fff]/g)?.length ?? 0
  const latinWords = text.match(/[A-Za-z0-9]+(?:'[A-Za-z0-9]+)?/g)?.length ?? 0
  return cjk + latinWords
}

let totalWordCount = 0
for (const post of posts) {
  totalWordCount += countChars(post.body ?? '')
}

const yearCountMap = new Map<number, number>()
for (const post of posts) {
  const pubDate = post.data.pubDate || post.data.published
  if (!pubDate) continue
  const y = pubDate.getFullYear()
  yearCountMap.set(y, (yearCountMap.get(y) ?? 0) + 1)
}

const yearCounts = Array.from(yearCountMap.entries())
  .sort((a, b) => b[0] - a[0])
  .map(([year, count]) => ({ year, count }))

const maxYearCount = Math.max(1, ...yearCounts.map((item) => item.count))

function formatWordCount(count: number, locale: string) {
  const formatted = count.toLocaleString()
  if (locale === 'zh' && count >= 10000) {
    const wan = (count / 10000).toFixed(1)
    return `${formatted}（${wan}万字）`
  }
  if (locale === 'en' && count >= 1000) {
    const k = (count / 1000).toFixed(1)
    return `${formatted} (${k}k)`
  }
  return formatted
}

function formatWordCountPrimary(count: number, locale: string) {
  if (locale === 'zh' && count >= 10000) {
    return (count / 10000).toFixed(1)
  }
  if (locale === 'en' && count >= 1000) {
    return (count / 1000).toFixed(1)
  }
  return count.toLocaleString()
}

function formatWordCountUnit(count: number, locale: string) {
  if (locale === 'zh' && count >= 10000) return '万字'
  if (locale === 'en' && count >= 1000) return 'k'
  return ''
}

const wordPrimary = formatWordCountPrimary(totalWordCount, locale)
const wordUnit = formatWordCountUnit(totalWordCount, locale)
const wordExact = totalWordCount.toLocaleString()
---

<section class="site-stats" aria-labelledby="site-stats-title">
  <div class="stats-hud__frame">
    <span class="stats-hud__corner stats-hud__corner--tl" aria-hidden="true"
    ></span>
    <span class="stats-hud__corner stats-hud__corner--tr" aria-hidden="true"
    ></span>
    <span class="stats-hud__corner stats-hud__corner--bl" aria-hidden="true"
    ></span>
    <span class="stats-hud__corner stats-hud__corner--br" aria-hidden="true"
    ></span>

    <div class="stats-hud__scanlines" aria-hidden="true"></div>
    <div class="stats-hud__sweep" aria-hidden="true"></div>

    <header class="stats-hud__chrome">
      <div class="stats-hud__chrome-left">
        <span class="stats-hud__led" aria-hidden="true"></span>
        <span class="stats-hud__tag font-mono">{t('sitestats.tag')}</span>
      </div>
      <span class="stats-hud__status font-mono">
        <span class="stats-hud__status-dot" aria-hidden="true"></span>
        {t('sitestats.status')}
      </span>
    </header>

    <div class="stats-hud__body">
      <h3 id="site-stats-title" class="stats-hud__title">
        {t('sitestats.title')}
      </h3>

      <div class="stats-hud__section">
        <div class="stats-hud__section-label font-mono">
          {t('sitestats.metrics')}
        </div>
        <div class="stats-metrics">
          <article class="stat-card">
            <p class="stat-label">{t('sitestats.operatingTime')}</p>
            <p class="stat-value">
              <span class="stat-num font-mono">
                {daysOperating.toLocaleString()}
              </span>
              <span class="stat-unit">{t('sitestats.daysUnit')}</span>
            </p>
            <p class="stat-detail">
              {t('sitestats.sinceStart', { start: formatYMD(startDate) })}
            </p>
            <p class="stat-sub">
              {
                t('sitestats.operatingTimeSub', {
                  years: durationParts.years,
                  months: durationParts.months,
                  days: durationParts.days,
                })
              }
            </p>
          </article>

          <article class="stat-card">
            <p class="stat-label">{t('sitestats.totalWords')}</p>
            <p class="stat-value">
              <span class="stat-num font-mono">{wordPrimary}</span>
              {
                wordUnit ? <span class="stat-unit">{wordUnit}</span> : null
              }
            </p>
            {
              wordUnit ? (
                <p
                  class="stat-detail"
                  title={formatWordCount(totalWordCount, locale)}
                >
                  {wordExact}
                </p>
              ) : null
            }
          </article>
        </div>
      </div>

      <div class="stats-hud__section">
        <div class="stats-hud__section-label font-mono">
          {t('sitestats.timeline')}
        </div>
        <p class="stat-label stat-label--inline">{t('sitestats.postsPerYear')}</p>
        {
          yearCounts.length ? (
            <ul class="year-bars">
              {yearCounts.map((item, index) => {
                const ratio = Math.round((item.count / maxYearCount) * 100)
                return (
                  <li
                    class="year-bar"
                    style={`--bar-ratio: ${ratio}%; --bar-delay: ${index * 70}ms`}
                  >
                    <span class="year-bar__mark" aria-hidden="true"></span>
                    <span class="year-bar__year font-mono">{item.year}</span>
                    <span class="year-bar__track" aria-hidden="true">
                      <span class="year-bar__fill" />
                    </span>
                    <span class="year-bar__count">
                      {t('sitestats.yearItemCount', { count: item.count })}
                    </span>
                  </li>
                )
              })}
            </ul>
          ) : (
            <p class="stats-empty">{t('sitestats.noData')}</p>
          )
        }
      </div>
    </div>

    <footer class="stats-hud__footer font-mono" aria-hidden="true">
      <span>{t('sitestats.footerLeft')}</span>
      <span class="stats-hud__footer-sep">//</span>
      <span>{t('sitestats.footerRight')}</span>
    </footer>
  </div>
</section>

<style>
  .site-stats {
    --stats-glow: color-mix(in srgb, var(--c-accent) 35%, transparent);
    --stats-line: color-mix(in srgb, var(--c-accent) 55%, transparent);
    --stats-panel: color-mix(in srgb, var(--c-surface) 88%, var(--c-accent-soft));
    --stats-scan: 4.5%;
    --stats-grid: 3%;

    margin: 1.75rem 0 2.25rem;
  }

  :global(:root.dark) .site-stats {
    --stats-glow: color-mix(in srgb, var(--c-accent) 55%, transparent);
    --stats-panel: color-mix(in srgb, #0b1016 82%, var(--c-accent-soft));
    --stats-scan: 8%;
    --stats-grid: 6%;
  }

  .stats-hud__frame {
    position: relative;
    overflow: hidden;
    padding: 1rem 1.15rem 0.85rem;

    border: 1px solid color-mix(in srgb, var(--c-accent) 28%, var(--c-border));
    border-radius: var(--c-radius-lg);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--c-accent) 6%, transparent),
        transparent 42%
      ),
      linear-gradient(
        color-mix(in srgb, var(--c-accent) var(--stats-grid), transparent) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--c-accent) var(--stats-grid), transparent) 1px,
        transparent 1px
      ),
      var(--stats-panel);
    background-size:
      auto,
      22px 22px,
      22px 22px,
      auto;
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--c-accent) 10%, transparent) inset,
      0 0 24px color-mix(in srgb, var(--c-accent) 12%, transparent),
      var(--c-shadow);
  }

  :global(:root.dark) .stats-hud__frame {
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--c-accent) 16%, transparent) inset,
      0 0 28px color-mix(in srgb, var(--c-accent) 22%, transparent),
      0 12px 40px rgba(0, 0, 0, 0.45);
  }

  .stats-hud__corner {
    position: absolute;
    z-index: 3;
    width: 0.7rem;
    height: 0.7rem;
    border-color: var(--c-accent);
    border-style: solid;
    pointer-events: none;
  }

  .stats-hud__corner--tl {
    top: 0.35rem;
    left: 0.35rem;
    border-width: 1.5px 0 0 1.5px;
  }

  .stats-hud__corner--tr {
    top: 0.35rem;
    right: 0.35rem;
    border-width: 1.5px 1.5px 0 0;
  }

  .stats-hud__corner--bl {
    bottom: 0.35rem;
    left: 0.35rem;
    border-width: 0 0 1.5px 1.5px;
  }

  .stats-hud__corner--br {
    right: 0.35rem;
    bottom: 0.35rem;
    border-width: 0 1.5px 1.5px 0;
  }

  .stats-hud__scanlines {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 2px,
      color-mix(in srgb, var(--c-accent) var(--stats-scan), transparent) 2px,
      color-mix(in srgb, var(--c-accent) var(--stats-scan), transparent) 3px
    );
    opacity: 0.55;
    mix-blend-mode: soft-light;
  }

  :global(:root.dark) .stats-hud__scanlines {
    opacity: 0.72;
    mix-blend-mode: screen;
  }

  .stats-hud__sweep {
    position: absolute;
    z-index: 2;
    top: -30%;
    left: 0;
    width: 100%;
    height: 28%;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      transparent,
      color-mix(in srgb, var(--c-accent) 14%, transparent),
      transparent
    );
    will-change: transform;
    animation: stats-hud-sweep 4.8s linear infinite;
  }

  .stats-hud__chrome,
  .stats-hud__body,
  .stats-hud__footer {
    position: relative;
    z-index: 1;
  }

  .stats-hud__chrome {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.95rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid
      color-mix(in srgb, var(--c-accent) 22%, var(--c-border));
  }

  .stats-hud__chrome-left {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-width: 0;
  }

  .stats-hud__led {
    flex-shrink: 0;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--c-accent);
    box-shadow: 0 0 8px var(--stats-glow);
    animation: stats-hud-blink 1.8s steps(1, end) infinite;
  }

  .stats-hud__tag,
  .stats-hud__status,
  .stats-hud__section-label,
  .stats-hud__footer {
    color: color-mix(in srgb, var(--c-accent) 78%, var(--c-muted));
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .stats-hud__tag {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .stats-hud__status {
    display: inline-flex;
    flex-shrink: 0;
    align-items: center;
    gap: 0.35rem;
  }

  .stats-hud__status-dot {
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: var(--c-accent);
    box-shadow: 0 0 6px var(--stats-glow);
    animation: stats-hud-blink 1.2s steps(1, end) infinite;
  }

  .stats-hud__title {
    margin: 0 0 1rem !important;
    color: var(--fg-deeper, var(--c-text));
    font-size: 1.2rem !important;
    font-weight: 700;
    letter-spacing: 0.03em;
    line-height: 1.3;
    text-shadow: 0 0 18px color-mix(in srgb, var(--c-accent) 18%, transparent);
  }

  .stats-hud__section + .stats-hud__section {
    margin-top: 1rem;
  }

  .stats-hud__section-label {
    margin-bottom: 0.7rem;
    opacity: 0.85;
  }

  .stats-metrics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .stat-card {
    padding: 0.85rem 0.95rem;
    border: 1px solid color-mix(in srgb, var(--c-accent) 24%, var(--c-border));
    border-radius: var(--c-radius);
    background: color-mix(in srgb, var(--c-bg) 55%, transparent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--c-accent) 6%, transparent)
      inset;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out);
  }

  .stat-card:hover {
    border-color: color-mix(in srgb, var(--c-accent) 55%, var(--c-border));
    background: color-mix(in srgb, var(--c-accent) 8%, var(--c-surface));
    box-shadow: 0 0 12px color-mix(in srgb, var(--c-accent) 16%, transparent);
  }

  .stat-label {
    margin: 0 0 0.4rem !important;
    color: var(--c-muted);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
  }

  .stat-label--inline {
    margin-bottom: 0.65rem !important;
  }

  .stat-value {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    margin: 0 !important;
    line-height: 1.1;
  }

  .stat-num {
    color: var(--fg-deeper, var(--c-text));
    font-size: clamp(1.45rem, 3vw, 1.85rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
    text-shadow: 0 0 14px color-mix(in srgb, var(--c-accent) 22%, transparent);
  }

  .stat-unit {
    color: var(--c-accent);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .stat-detail,
  .stat-sub {
    margin: 0.35rem 0 0 !important;
    color: var(--c-muted);
    font-size: 0.8rem;
    line-height: 1.45;
  }

  .stat-sub {
    opacity: 0.88;
  }

  .year-bars {
    display: grid;
    gap: 0.55rem;
    margin: 0 !important;
    padding: 0.85rem 0.95rem !important;
    list-style: none;
    border: 1px solid color-mix(in srgb, var(--c-accent) 24%, var(--c-border));
    border-radius: var(--c-radius);
    background: color-mix(in srgb, var(--c-bg) 55%, transparent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--c-accent) 6%, transparent)
      inset;
  }

  .year-bar {
    display: grid;
    grid-template-columns: 0.28rem 3.1rem 1fr auto;
    gap: 0.55rem;
    align-items: center;
    position: relative;
    margin: 0 !important;
    padding: 0 !important;
  }

  .year-bar::before {
    content: none !important;
    display: none !important;
  }

  .year-bar__mark {
    width: 0.28rem;
    height: 0.28rem;
    border-radius: 1px;
    background: var(--c-accent);
    box-shadow: 0 0 6px var(--stats-glow);
  }

  .year-bar__year {
    color: var(--fg-deeper, var(--c-text));
    font-size: 0.84rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .year-bar__track {
    position: relative;
    overflow: hidden;
    height: 0.38rem;
    border-radius: 1px;
    background: color-mix(in srgb, var(--c-border) 80%, transparent);
  }

  .year-bar__fill {
    display: block;
    width: var(--bar-ratio);
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--c-accent) 45%, transparent),
      var(--c-accent)
    );
    box-shadow: 0 0 10px color-mix(in srgb, var(--c-accent) 35%, transparent);
    transform-origin: left center;
    animation: stats-hud-bar-in 560ms var(--ease-out, ease) both;
    animation-delay: var(--bar-delay, 0ms);
  }

  .year-bar__count {
    min-width: 3.4rem;
    color: var(--c-muted);
    font-size: 0.8rem;
    text-align: right;
    white-space: nowrap;
  }

  .stats-empty {
    margin: 0 !important;
    padding: 0.85rem 0.95rem;
    color: var(--c-muted);
    font-size: 0.88rem;
    border: 1px dashed color-mix(in srgb, var(--c-accent) 22%, var(--c-border));
    border-radius: var(--c-radius);
  }

  .stats-hud__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: 0.9rem;
    padding-top: 0.55rem;
    border-top: 1px dashed
      color-mix(in srgb, var(--c-accent) 20%, var(--c-border));
    opacity: 0.72;
  }

  .stats-hud__footer-sep {
    opacity: 0.45;
  }

  @keyframes stats-hud-sweep {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(460%);
    }
  }

  @keyframes stats-hud-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.2;
    }
  }

  @keyframes stats-hud-bar-in {
    from {
      transform: scaleX(0);
      opacity: 0.25;
    }
    to {
      transform: scaleX(1);
      opacity: 1;
    }
  }

  @media (max-width: 640px) {
    .stats-hud__frame {
      padding: 0.9rem 0.85rem 0.75rem;
    }

    .stats-metrics {
      grid-template-columns: 1fr;
    }

    .year-bar {
      grid-template-columns: 0.28rem 2.75rem 1fr auto;
      gap: 0.45rem;
    }

    .year-bar__count {
      min-width: 3rem;
    }

    .stats-hud__footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.2rem;
    }

    .stats-hud__footer-sep {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .stats-hud__sweep,
    .stats-hud__led,
    .stats-hud__status-dot,
    .year-bar__fill {
      animation: none;
    }

    .stats-hud__sweep {
      will-change: auto;
      opacity: 0;
    }

    .stats-hud__led,
    .stats-hud__status-dot {
      opacity: 1;
    }

    .stat-card {
      transition: none;
    }
  }
</style>
