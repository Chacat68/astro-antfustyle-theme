---
import { getLocale, useTranslations } from '~/i18n/translate'
import { getLocalizedBlogPosts } from '~/utils/data'

const locale = getLocale(Astro.currentLocale)
const t = useTranslations(locale)

// Blog posts
const posts = await getLocalizedBlogPosts(Astro.currentLocale)

const now = new Date()

const postDates = posts
  .map((post) => post.data.pubDate || post.data.published)
  .filter((d): d is Date => d instanceof Date)

const startDate = postDates.length
  ? new Date(Math.min(...postDates.map((d) => d.valueOf())))
  : now

function formatYMD(date: Date) {
  return date.toISOString().split('T')[0]
}

function getDurationParts(from: Date, to: Date) {
  let years = to.getFullYear() - from.getFullYear()
  let months = to.getMonth() - from.getMonth()
  let days = to.getDate() - from.getDate()

  if (days < 0) {
    const lastMonth = new Date(to.getFullYear(), to.getMonth(), 0)
    days += lastMonth.getDate()
    months -= 1
  }

  if (months < 0) {
    months += 12
    years -= 1
  }

  return {
    years: Math.max(0, years),
    months: Math.max(0, months),
    days: Math.max(0, days),
  }
}

const durationParts = getDurationParts(startDate, now)
const daysOperating = Math.max(
  0,
  Math.floor((now.valueOf() - startDate.valueOf()) / 86400000) + 1
)

function countChars(text: string) {
  const cjk = text.match(/[\u4e00-\u9fff]/g)?.length ?? 0
  const latinWords = text.match(/[A-Za-z0-9]+(?:'[A-Za-z0-9]+)?/g)?.length ?? 0
  return cjk + latinWords
}

let totalWordCount = 0
for (const post of posts) {
  totalWordCount += countChars(post.body ?? '')
}

const yearCountMap = new Map<number, number>()
for (const post of posts) {
  const pubDate = post.data.pubDate || post.data.published
  if (!pubDate) continue
  const y = pubDate.getFullYear()
  yearCountMap.set(y, (yearCountMap.get(y) ?? 0) + 1)
}

const yearCounts = Array.from(yearCountMap.entries())
  .sort((a, b) => b[0] - a[0])
  .map(([year, count]) => ({ year, count }))

const maxYearCount = Math.max(1, ...yearCounts.map((item) => item.count))

function formatWordCount(count: number, locale: string) {
  const formatted = count.toLocaleString()
  if (locale === 'zh' && count >= 10000) {
    const wan = (count / 10000).toFixed(1)
    return `${formatted}（${wan}万字）`
  }
  if (locale === 'en' && count >= 1000) {
    const k = (count / 1000).toFixed(1)
    return `${formatted} (${k}k)`
  }
  return formatted
}

function formatWordCountPrimary(count: number, locale: string) {
  if (locale === 'zh' && count >= 10000) {
    return (count / 10000).toFixed(1)
  }
  if (locale === 'en' && count >= 1000) {
    return (count / 1000).toFixed(1)
  }
  return count.toLocaleString()
}

function formatWordCountUnit(count: number, locale: string) {
  if (locale === 'zh' && count >= 10000) return '万字'
  if (locale === 'en' && count >= 1000) return 'k'
  return ''
}

const wordPrimary = formatWordCountPrimary(totalWordCount, locale)
const wordUnit = formatWordCountUnit(totalWordCount, locale)
const wordExact = totalWordCount.toLocaleString()
---

<section class="site-stats" aria-labelledby="site-stats-title">
  <div class="neon-sign" data-neon>
    <span class="neon-bolt neon-bolt--tl" aria-hidden="true"></span>
    <span class="neon-bolt neon-bolt--tr" aria-hidden="true"></span>
    <span class="neon-bolt neon-bolt--bl" aria-hidden="true"></span>
    <span class="neon-bolt neon-bolt--br" aria-hidden="true"></span>

    <div class="neon-tube neon-tube--outer" aria-hidden="true"></div>
    <div class="neon-tube neon-tube--inner" aria-hidden="true"></div>

    <header class="stats-header">
      <h3 id="site-stats-title" class="neon-title font-condensed">
        {t('sitestats.title')}
      </h3>
      <span class="neon-live font-mono" aria-hidden="true">
        <span class="neon-live__dot"></span>
        ON AIR
      </span>
    </header>

    <div class="stats-metrics">
      <article class="stat-card stat-card--cyan">
        <p class="stat-label">{t('sitestats.operatingTime')}</p>
        <p class="stat-value">
          <span class="stat-num font-mono neon-glow-cyan">
            {daysOperating.toLocaleString()}
          </span>
          <span class="stat-unit neon-glow-cyan">{t('sitestats.daysUnit')}</span>
        </p>
        <p class="stat-detail">
          {t('sitestats.sinceStart', { start: formatYMD(startDate) })}
        </p>
        <p class="stat-sub">
          {
            t('sitestats.operatingTimeSub', {
              years: durationParts.years,
              months: durationParts.months,
              days: durationParts.days,
            })
          }
        </p>
      </article>

      <article class="stat-card stat-card--pink">
        <p class="stat-label">{t('sitestats.totalWords')}</p>
        <p class="stat-value">
          <span class="stat-num font-mono neon-glow-pink">{wordPrimary}</span>
          {
            wordUnit ? (
              <span class="stat-unit neon-glow-pink">{wordUnit}</span>
            ) : null
          }
        </p>
        {
          wordUnit ? (
            <p
              class="stat-detail"
              title={formatWordCount(totalWordCount, locale)}
            >
              {wordExact}
            </p>
          ) : null
        }
      </article>
    </div>

    <div class="stats-years">
      <p class="stat-label stat-label--section">{t('sitestats.postsPerYear')}</p>
      {
        yearCounts.length ? (
          <ul class="year-bars">
            {yearCounts.map((item, index) => {
              const ratio = Math.round((item.count / maxYearCount) * 100)
              return (
                <li
                  class="year-bar"
                  style={`--bar-ratio: ${ratio}%; --bar-delay: ${index * 80}ms`}
                >
                  <span class="year-bar__year font-mono">{item.year}</span>
                  <span class="year-bar__track" aria-hidden="true">
                    <span class="year-bar__fill" />
                  </span>
                  <span class="year-bar__count">
                    {t('sitestats.yearItemCount', { count: item.count })}
                  </span>
                </li>
              )
            })}
          </ul>
        ) : (
          <p class="stats-empty">{t('sitestats.noData')}</p>
        )
      }
    </div>
  </div>
</section>

<style>
  .site-stats {
    --neon-cyan: #5eead4;
    --neon-cyan-core: #ecfeff;
    --neon-pink: #fb7185;
    --neon-pink-core: #fff1f2;
    --neon-amber: #fbbf24;
    --sign-bg: #0a0c10;
    --sign-face: #11151c;
    --sign-metal: #2a303a;
    --sign-muted: rgba(226, 232, 240, 0.55);

    margin: 1.85rem 0 2.35rem;
  }

  .neon-sign {
    position: relative;
    overflow: hidden;
    padding: 1.35rem 1.3rem 1.35rem;

    border: 3px solid var(--sign-metal);
    border-radius: 1rem;
    background:
      radial-gradient(
        ellipse 70% 55% at 50% 0%,
        rgba(94, 234, 212, 0.12),
        transparent 55%
      ),
      radial-gradient(
        ellipse 55% 45% at 85% 90%,
        rgba(251, 113, 133, 0.1),
        transparent 50%
      ),
      linear-gradient(160deg, #151a22 0%, var(--sign-face) 45%, #0c0f14 100%);
    box-shadow:
      0 0 0 1px #07090c,
      inset 0 0 0 1px rgba(255, 255, 255, 0.05),
      inset 0 0 40px rgba(0, 0, 0, 0.45),
      0 18px 40px rgba(0, 0, 0, 0.28),
      0 0 28px rgba(94, 234, 212, 0.12),
      0 0 48px rgba(251, 113, 133, 0.08);
    color: #e2e8f0;
    isolation: isolate;
  }

  .neon-sign::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.18;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 18px 18px;
    mix-blend-mode: soft-light;
  }

  .neon-sign::after {
    content: '';
    position: absolute;
    inset: 10px;
    z-index: 0;
    pointer-events: none;
    border: 1px solid rgba(148, 163, 184, 0.12);
    border-radius: 0.7rem;
  }

  .neon-bolt {
    position: absolute;
    z-index: 2;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background:
      radial-gradient(circle at 30% 30%, #d4d4d8, #71717a 55%, #3f3f46);
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.45),
      0 1px 2px rgba(0, 0, 0, 0.55);
  }

  .neon-bolt--tl {
    top: 0.55rem;
    left: 0.55rem;
  }
  .neon-bolt--tr {
    top: 0.55rem;
    right: 0.55rem;
  }
  .neon-bolt--bl {
    bottom: 0.55rem;
    left: 0.55rem;
  }
  .neon-bolt--br {
    bottom: 0.55rem;
    right: 0.55rem;
  }

  .neon-tube {
    position: absolute;
    z-index: 1;
    pointer-events: none;
    border-radius: 0.85rem;
  }

  .neon-tube--outer {
    inset: 0.72rem;
    border: 2px solid color-mix(in srgb, var(--neon-cyan) 70%, white);
    box-shadow:
      0 0 4px var(--neon-cyan),
      0 0 14px rgba(94, 234, 212, 0.55),
      0 0 28px rgba(94, 234, 212, 0.28),
      inset 0 0 10px rgba(94, 234, 212, 0.18);
    animation: neon-breathe 4.8s ease-in-out infinite;
  }

  .neon-tube--inner {
    inset: 1.05rem;
    border: 1.5px solid color-mix(in srgb, var(--neon-pink) 75%, white);
    opacity: 0.72;
    box-shadow:
      0 0 4px var(--neon-pink),
      0 0 16px rgba(251, 113, 133, 0.4),
      inset 0 0 8px rgba(251, 113, 133, 0.15);
    animation: neon-breathe 5.6s ease-in-out infinite reverse;
  }

  .stats-header,
  .stats-metrics,
  .stats-years {
    position: relative;
    z-index: 2;
  }

  .stats-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1.15rem;
    padding-inline: 0.35rem;
  }

  .neon-title {
    margin: 0 !important;
    color: var(--neon-amber);
    font-size: clamp(1.15rem, 3.4vw, 1.45rem) !important;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-shadow:
      0 0 2px #fff7d6,
      0 0 8px rgba(251, 191, 36, 0.95),
      0 0 18px rgba(251, 191, 36, 0.7),
      0 0 36px rgba(251, 191, 36, 0.35);
    animation: neon-flicker 7s linear infinite;
  }

  .neon-live {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
    color: color-mix(in srgb, var(--neon-pink) 80%, white);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-shadow:
      0 0 6px rgba(251, 113, 133, 0.8),
      0 0 14px rgba(251, 113, 133, 0.45);
  }

  .neon-live__dot {
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: var(--neon-pink);
    box-shadow:
      0 0 6px var(--neon-pink),
      0 0 14px rgba(251, 113, 133, 0.7);
    animation: neon-pulse 1.6s ease-in-out infinite;
  }

  .stats-metrics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
    margin-bottom: 1.2rem;
  }

  .stat-card {
    padding: 0.9rem 0.95rem;
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: 0.65rem;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.03),
      rgba(0, 0, 0, 0.22)
    );
    box-shadow: inset 0 0 18px rgba(0, 0, 0, 0.28);
  }

  .stat-card--cyan {
    border-color: rgba(94, 234, 212, 0.28);
    box-shadow:
      inset 0 0 18px rgba(0, 0, 0, 0.28),
      0 0 18px rgba(94, 234, 212, 0.08);
  }

  .stat-card--pink {
    border-color: rgba(251, 113, 133, 0.28);
    box-shadow:
      inset 0 0 18px rgba(0, 0, 0, 0.28),
      0 0 18px rgba(251, 113, 133, 0.08);
  }

  .stat-label {
    margin: 0 0 0.45rem !important;
    color: var(--sign-muted);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .stat-label--section {
    margin-bottom: 0.65rem !important;
    color: color-mix(in srgb, var(--neon-cyan) 55%, white);
    text-shadow: 0 0 10px rgba(94, 234, 212, 0.35);
  }

  .stat-value {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    margin: 0 !important;
    line-height: 1.05;
  }

  .stat-num {
    font-size: clamp(1.65rem, 3.6vw, 2.05rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }

  .stat-unit {
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .neon-glow-cyan {
    color: var(--neon-cyan-core);
    text-shadow:
      0 0 2px #fff,
      0 0 8px var(--neon-cyan),
      0 0 18px rgba(94, 234, 212, 0.85),
      0 0 34px rgba(45, 212, 191, 0.45);
  }

  .neon-glow-pink {
    color: var(--neon-pink-core);
    text-shadow:
      0 0 2px #fff,
      0 0 8px var(--neon-pink),
      0 0 18px rgba(251, 113, 133, 0.85),
      0 0 34px rgba(244, 63, 94, 0.4);
  }

  .stat-detail,
  .stat-sub {
    margin: 0.4rem 0 0 !important;
    color: var(--sign-muted);
    font-size: 0.8rem;
    line-height: 1.45;
  }

  .stat-sub {
    opacity: 0.85;
  }

  .year-bars {
    display: grid;
    gap: 0.6rem;
    margin: 0 !important;
    padding: 0 !important;
    list-style: none;
  }

  .year-bar {
    display: grid;
    grid-template-columns: 3.25rem 1fr auto;
    gap: 0.65rem;
    align-items: center;
    position: relative;
    margin: 0 !important;
    padding: 0 !important;
  }

  .year-bar::before {
    content: none !important;
    display: none !important;
  }

  .year-bar__year {
    color: color-mix(in srgb, var(--neon-cyan) 70%, white);
    font-size: 0.86rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    text-shadow: 0 0 8px rgba(94, 234, 212, 0.45);
  }

  .year-bar__track {
    position: relative;
    overflow: hidden;
    height: 0.48rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.45);
  }

  .year-bar__fill {
    display: block;
    width: var(--bar-ratio);
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(
      90deg,
      rgba(94, 234, 212, 0.35),
      var(--neon-cyan) 45%,
      var(--neon-pink)
    );
    box-shadow:
      0 0 6px rgba(94, 234, 212, 0.75),
      0 0 14px rgba(251, 113, 133, 0.45);
    transform-origin: left center;
    animation: neon-bar-in 620ms var(--ease-out, ease) both;
    animation-delay: var(--bar-delay, 0ms);
  }

  .year-bar__count {
    min-width: 3.5rem;
    color: var(--sign-muted);
    font-size: 0.8rem;
    text-align: right;
    white-space: nowrap;
  }

  .stats-empty {
    margin: 0.55rem 0 0 !important;
    color: var(--sign-muted);
    font-size: 0.88rem;
  }

  @keyframes neon-breathe {
    0%,
    100% {
      opacity: 0.78;
      filter: saturate(1);
    }
    50% {
      opacity: 1;
      filter: saturate(1.15);
    }
  }

  @keyframes neon-pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.55;
      transform: scale(0.85);
    }
  }

  @keyframes neon-flicker {
    0%,
    19%,
    21%,
    23%,
    25%,
    54%,
    56%,
    100% {
      opacity: 1;
    }
    20%,
    24%,
    55% {
      opacity: 0.72;
    }
    22% {
      opacity: 0.88;
    }
  }

  @keyframes neon-bar-in {
    from {
      transform: scaleX(0);
      opacity: 0.2;
    }
    to {
      transform: scaleX(1);
      opacity: 1;
    }
  }

  @media (max-width: 640px) {
    .neon-sign {
      padding: 1.2rem 1rem 1.15rem;
    }

    .neon-tube--outer {
      inset: 0.55rem;
    }

    .neon-tube--inner {
      inset: 0.85rem;
    }

    .stats-header {
      flex-wrap: wrap;
    }

    .stats-metrics {
      grid-template-columns: 1fr;
    }

    .year-bar {
      grid-template-columns: 2.75rem 1fr auto;
      gap: 0.5rem;
    }

    .year-bar__count {
      min-width: 3rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .neon-tube--outer,
    .neon-tube--inner,
    .neon-title,
    .neon-live__dot,
    .year-bar__fill {
      animation: none;
    }
  }
</style>
