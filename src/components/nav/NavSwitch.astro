---
import { getLocale, useTranslations } from '~/i18n/translate'

const locale = getLocale(Astro.currentLocale)
const t = useTranslations(locale)
---

<button
  id="nav-open-button"
  class="touch-target hidden lt-lg:inline-flex op-60 hover:op-100 op-transition"
  title={t('a11y.navigation')}
  aria-label={t('a11y.navigation')}
  aria-expanded="false"
  aria-controls="nav-panel"
>
  <div u-i-ri-menu-line></div>
</button>

<div
  id="nav-panel"
  class="hidden! z-200 fixed top-50vh left-50vw translate-x--50% translate-y--50%
    overflow-y-auto flex-col gap-5
    w-90% max-w-md max-h-80vh py-4 px-6 rounded-lg
  border shadow-custom_0_0_10_0 text-(--c-text)"
>
  <ul>
    <slot name="text" />
  </ul>
  <div class="flex justify-center items-center gap-4">
    <slot name="icon" />
  </div>
</div>

<style>
  #nav-panel {
    /* sticky + backdrop-filter 的导航会形成 fixed 包含块，须用 vh/vw 相对视口 */
    display: flex;
    max-height: min(80vh, calc(100dvh - 2rem));
    border-color: var(--c-border);
    background-color: var(--c-bg);
  }
</style>

<script>
  import { toggleFadeEffect } from '~/utils/misc'

  document.addEventListener('astro:page-load', () => {
    const navOpenButton = document.getElementById('nav-open-button')
    const navPanel = document.getElementById('nav-panel')

    const setExpanded = (expanded: boolean) => {
      navOpenButton?.setAttribute('aria-expanded', expanded ? 'true' : 'false')
    }

    const isNavPanelOpen = () => {
      return navPanel ? !navPanel.classList.contains('hidden!') : false
    }

    const openNavPanel = () => {
      toggleFadeEffect('backdrop', true, 'hidden')
      toggleFadeEffect('nav-panel', true, 'hidden!')
      setExpanded(true)
    }

    const closeNavPanel = () => {
      toggleFadeEffect('nav-panel', false, 'hidden!')
      toggleFadeEffect('backdrop', false, 'hidden')
      setExpanded(false)
    }

    const handleBtnClickToToggle = () => {
      if (isNavPanelOpen()) {
        closeNavPanel()
        return
      }

      openNavPanel()
    }

    navOpenButton?.addEventListener('click', handleBtnClickToToggle)
  })
</script>
