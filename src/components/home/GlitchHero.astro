---
/**
 * 首页 Three.js 故障艺术展示台 + 功能入口
 * 中：品牌字；右：功能入口竖栏；左下：社交；右下：搜索 / 语言 / 日夜 / RSS / 更新日志
 */
import Link from '~/components/base/Link.astro'
import SearchSwitch from '~/components/widgets/SearchSwitch.astro'
import LanguageSwitch from '~/components/widgets/LanguageSwitch.astro'
import ThemeSwitch from '~/components/widgets/ThemeSwitch.astro'
import RssLink from '~/components/widgets/RssLink.astro'
import { UI } from '~/config'
import { ensureTrailingSlash } from '~/utils/path'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { getLocale, useTranslations } from '~/i18n/translate'

const locale = getLocale(Astro.currentLocale)
const t = useTranslations(locale)

const line1 = t('home.glitch.line1')
const line2 = t('home.glitch.line2')

const navKeyByPath: Record<string, string> = {
  '/blog': 'nav.blog',
  '/projects': 'nav.projects',
  '/friends': 'nav.friends',
  '/photos': 'nav.photos',
  '/gallery': 'nav.gallery',
}

const iconByPath: Record<string, string> = {
  '/blog': 'i-ri-article-line',
  '/projects': 'i-ri-code-box-line',
  '/friends': 'i-ri-group-line',
  '/photos': 'i-ri-camera-ai-line',
  '/gallery': 'i-ri-palette-line',
}

const changelogHref = ensureTrailingSlash(
  getRelativeLocaleUrl(locale, 'changelog')
)

const portals = [
  {
    href: ensureTrailingSlash(getRelativeLocaleUrl(locale, 'about')),
    label: t('nav.about'),
    icon: 'i-ri-user-smile-line',
  },
  ...UI.internalNavs
    .filter((item) => item.path.replace(/\/+$/, '') !== '/changelog')
    .map((item) => {
      const path = item.path.replace(/\/+$/, '')
      const key = navKeyByPath[path]
      return {
        href: ensureTrailingSlash(
          getRelativeLocaleUrl(locale, path.replace(/^\//, ''))
        ),
        label: key ? t(key) : item.title,
        icon:
          ('icon' in item && item.icon) ||
          iconByPath[path] ||
          'i-ri-arrow-right-up-line',
      }
    }),
]
---

<section
  class="glitch-hero"
  id="glitch-hero"
  data-glitch-hero
  aria-label={t('home.glitch.aria')}
>
  <div class="glitch-hero__canvas" data-glitch-canvas aria-hidden="true"></div>

  <div class="glitch-hero__content">
    <header class="glitch-hero__brand">
      <div class="glitch-hero__frame" aria-hidden="true">
        <span class="glitch-hero__x"></span>
        <span class="glitch-hero__bar"></span>
      </div>
      <h1 class="glitch-hero__title" data-glitch-text>
        <span class="glitch-hero__line" data-text={line1}>{line1}</span>
        <span class="glitch-hero__line" data-text={line2}>{line2}</span>
      </h1>
    </header>
  </div>

  <nav class="glitch-hero__portals" aria-label={t('home.glitch.portalsAria')}>
    {
      portals.map((item, index) => {
        const idx = String(index + 1).padStart(2, '0')
        return (
          <Link
            href={item.href}
            class="glitch-hero__portal"
            data-index={idx}
            style={`--portal-i: ${index}`}
          >
            <span class="glitch-hero__portal-corners" aria-hidden="true" />
            <span class="glitch-hero__portal-scan" aria-hidden="true" />
            <span class="glitch-hero__portal-index" aria-hidden="true">
              {idx}
            </span>
            <span
              class={`${item.icon} glitch-hero__portal-icon`}
              aria-hidden="true"
            />
            <span class="glitch-hero__portal-label" data-text={item.label}>
              {item.label}
            </span>
            <span class="glitch-hero__portal-meta" aria-hidden="true">
              SRC/{idx}
            </span>
          </Link>
        )
      })
    }
  </nav>

  <nav class="glitch-hero__dock glitch-hero__dock--social" aria-label={t('home.glitch.socialsAria')}>
    <span class="glitch-hero__dock-tag" aria-hidden="true">SIG</span>
    {
      UI.socialLinks.map((item) => (
        <Link
          href={item.link}
          title={item.title}
          class="glitch-hero__dock-link"
          aria-label={item.title}
          external
        >
          {'icon' in item && <span class={item.icon} aria-hidden="true" />}
        </Link>
      ))
    }
  </nav>

  <div class="glitch-hero__dock glitch-hero__dock--tools" aria-label={t('home.glitch.toolsAria')}>
    <span class="glitch-hero__dock-tag" aria-hidden="true">SYS</span>
    <SearchSwitch />
    <LanguageSwitch />
    <ThemeSwitch />
    <RssLink class="glitch-hero__rss" />
    <Link
      href={changelogHref}
      class="glitch-hero__dock-link"
      title={t('nav.changelog')}
      aria-label={t('nav.changelog')}
    >
      <span class="i-ri-draft-line" aria-hidden="true"></span>
    </Link>
  </div>
</section>

<style>
  .glitch-hero {
    --gh-fg: #f4f4f2;
    --gh-muted: rgba(244, 244, 242, 0.5);
    --gh-red: #ff2a4a;
    --gh-cyan: #2ad4ff;

    position: relative;
    display: grid;
    place-items: center;
    width: 100%;
    min-height: 100svh;
    min-height: 100dvh;
    overflow: hidden;
    isolation: isolate;
    color: var(--gh-fg);
    background: #050505;
  }

  .glitch-hero__canvas {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
  }

  .glitch-hero__canvas :global(canvas) {
    display: block;
    width: 100% !important;
    height: 100% !important;
  }

  /* 底栏坞：左社交 / 右工具（不用 backdrop-filter，避免搜索面板错位） */
  .glitch-hero__dock {
    position: absolute;
    z-index: 2;
    bottom: max(1rem, env(safe-area-inset-bottom));
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgba(244, 244, 242, 0.18);
    background: rgba(5, 5, 5, 0.78);
    color: var(--gh-fg);
    clip-path: polygon(
      0 0,
      calc(100% - 8px) 0,
      100% 8px,
      100% 100%,
      8px 100%,
      0 calc(100% - 8px)
    );
  }

  .glitch-hero__dock--social {
    left: max(1rem, env(safe-area-inset-left));
  }

  .glitch-hero__dock--tools {
    right: max(1rem, env(safe-area-inset-right));
  }

  .glitch-hero__dock-tag {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    color: rgba(244, 244, 242, 0.35);
    padding-inline-end: 0.15rem;
    border-inline-end: 1px solid rgba(244, 244, 242, 0.16);
    margin-inline-end: 0.1rem;
  }

  .glitch-hero__dock :global(a),
  .glitch-hero__dock :global(button),
  .glitch-hero__dock-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--gh-fg) !important;
    opacity: 0.62 !important;
    font-size: 1.05rem;
    line-height: 1;
    transition: opacity 160ms ease;
  }

  .glitch-hero__dock :global(a:hover),
  .glitch-hero__dock :global(a:focus-visible),
  .glitch-hero__dock :global(button:hover),
  .glitch-hero__dock :global(button:focus-visible),
  .glitch-hero__dock-link:hover,
  .glitch-hero__dock-link:focus-visible {
    opacity: 1 !important;
  }

  .glitch-hero__dock :global(#theme-switch),
  .glitch-hero__dock :global(#search-switch) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .glitch-hero__rss {
    opacity: 0.62 !important;
  }

  .glitch-hero__content {
    position: relative;
    z-index: 1;
    display: grid;
    justify-items: center;
    gap: 1.25rem;
    width: auto;
    padding:
      max(3.5rem, env(safe-area-inset-top))
      1.25rem
      max(6.5rem, calc(env(safe-area-inset-bottom) + 5rem));
  }

  .glitch-hero__brand {
    position: relative;
    display: grid;
    place-items: center;
    width: min(42vw, 240px);
    aspect-ratio: 1;
    border: 1px solid rgba(244, 244, 242, 0.85);
    animation: brand-glitch 9.5s steps(1, end) infinite;
  }

  .glitch-hero__frame {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .glitch-hero__x::before,
  .glitch-hero__x::after {
    content: '';
    position: absolute;
    inset: 8% auto;
    left: 50%;
    width: 1px;
    height: 84%;
    background: rgba(244, 244, 242, 0.28);
  }

  .glitch-hero__x::before {
    transform: translateX(-50%) rotate(45deg);
  }

  .glitch-hero__x::after {
    transform: translateX(-50%) rotate(-45deg);
  }

  .glitch-hero__bar {
    position: absolute;
    left: 18%;
    right: 18%;
    bottom: 22%;
    height: 5px;
    background: var(--gh-fg);
    box-shadow:
      -2px 0 0 var(--gh-red),
      2px 0 0 var(--gh-cyan);
    animation: brand-bar-glitch 9.5s steps(1, end) infinite;
  }

  .glitch-hero__title {
    position: relative;
    z-index: 1;
    margin: 0;
    display: grid;
    gap: 0.05em;
    font-weight: 700;
    font-size: clamp(2.2rem, 7vw, 3.2rem);
    line-height: 0.95;
    letter-spacing: 0.08em;
    text-align: center;
    text-transform: uppercase;
    animation: brand-title-glitch 7.2s steps(1, end) infinite;
  }

  .glitch-hero__line {
    position: relative;
    display: block;
  }

  .glitch-hero__line::before,
  .glitch-hero__line::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    overflow: hidden;
    opacity: 0.65;
    pointer-events: none;
  }

  .glitch-hero__line::before {
    color: var(--gh-red);
    transform: translate(-1.5px, 0);
    clip-path: inset(0 0 55% 0);
    mix-blend-mode: screen;
    animation: brand-rgb-red 7.2s steps(1, end) infinite;
  }

  .glitch-hero__line::after {
    color: var(--gh-cyan);
    transform: translate(1.5px, 0);
    clip-path: inset(45% 0 0 0);
    mix-blend-mode: screen;
    animation: brand-rgb-cyan 7.2s steps(1, end) infinite;
    animation-delay: 0.08s;
  }

  /* 偶发故障：长周期大半时间静止，短促几帧错位 / 闪白 */
  @keyframes brand-glitch {
    0%,
    41%,
    46%,
    82%,
    88%,
    100% {
      transform: none;
      filter: none;
      border-color: rgba(244, 244, 242, 0.85);
    }

    42% {
      transform: translate(-2px, 1px);
      filter: contrast(1.15) saturate(1.25);
      border-color: color-mix(in srgb, var(--gh-cyan) 70%, #fff);
    }

    43% {
      transform: translate(3px, -1px);
      filter: contrast(1.35) hue-rotate(-8deg);
      border-color: color-mix(in srgb, var(--gh-red) 75%, #fff);
    }

    44% {
      transform: translate(-1px, 0);
      filter: brightness(1.35);
    }

    45% {
      transform: translate(1px, 1px);
      filter: none;
    }

    83% {
      transform: translate(2px, 0);
      border-color: rgba(244, 244, 242, 0.45);
    }

    84% {
      transform: translate(-3px, 1px);
      filter: contrast(1.2);
      border-color: var(--gh-cyan);
    }

    85%,
    86% {
      transform: translate(1px, -1px);
      filter: brightness(1.25);
    }

    87% {
      transform: none;
      filter: none;
    }
  }

  @keyframes brand-title-glitch {
    0%,
    41%,
    46%,
    82%,
    88%,
    100% {
      transform: none;
      opacity: 1;
      text-shadow: none;
    }

    42% {
      transform: translate(2px, 0);
      opacity: 0.82;
      text-shadow:
        -2px 0 var(--gh-red),
        2px 0 var(--gh-cyan);
    }

    43% {
      transform: translate(-3px, 1px);
      opacity: 1;
      text-shadow:
        3px 0 var(--gh-red),
        -2px 0 var(--gh-cyan);
    }

    44% {
      transform: translate(1px, -1px);
      opacity: 0.7;
      text-shadow: none;
    }

    45% {
      transform: none;
      opacity: 1;
    }

    83% {
      transform: skewX(-4deg) translateX(2px);
      opacity: 0.88;
    }

    84% {
      transform: skewX(3deg) translateX(-2px);
      text-shadow:
        -3px 0 var(--gh-red),
        3px 0 var(--gh-cyan);
    }

    85% {
      transform: none;
      opacity: 0.55;
      text-shadow: none;
    }

    86%,
    87% {
      transform: none;
      opacity: 1;
    }
  }

  @keyframes brand-rgb-red {
    0%,
    41%,
    46%,
    82%,
    88%,
    100% {
      transform: translate(-1.5px, 0);
      opacity: 0.65;
      clip-path: inset(0 0 55% 0);
    }

    42% {
      transform: translate(-7px, 1px);
      opacity: 0.95;
      clip-path: inset(8% 0 35% 0);
    }

    43% {
      transform: translate(5px, -2px);
      opacity: 0.85;
      clip-path: inset(0 0 72% 0);
    }

    44% {
      transform: translate(-4px, 0);
      clip-path: inset(30% 0 20% 0);
    }

    45% {
      transform: translate(-1.5px, 0);
      opacity: 0.65;
      clip-path: inset(0 0 55% 0);
    }

    83% {
      transform: translate(-9px, 0);
      opacity: 1;
      clip-path: inset(0 0 40% 0);
    }

    84% {
      transform: translate(6px, 2px);
      clip-path: inset(55% 0 0 0);
    }

    85% {
      transform: translate(-2px, -1px);
      opacity: 0.4;
    }

    86%,
    87% {
      transform: translate(-1.5px, 0);
      opacity: 0.65;
      clip-path: inset(0 0 55% 0);
    }
  }

  @keyframes brand-rgb-cyan {
    0%,
    41%,
    46%,
    82%,
    88%,
    100% {
      transform: translate(1.5px, 0);
      opacity: 0.65;
      clip-path: inset(45% 0 0 0);
    }

    42% {
      transform: translate(8px, -1px);
      opacity: 0.95;
      clip-path: inset(20% 0 15% 0);
    }

    43% {
      transform: translate(-5px, 2px);
      opacity: 0.85;
      clip-path: inset(60% 0 0 0);
    }

    44% {
      transform: translate(4px, 0);
      clip-path: inset(10% 0 50% 0);
    }

    45% {
      transform: translate(1.5px, 0);
      opacity: 0.65;
      clip-path: inset(45% 0 0 0);
    }

    83% {
      transform: translate(9px, 1px);
      opacity: 1;
      clip-path: inset(35% 0 0 0);
    }

    84% {
      transform: translate(-6px, -2px);
      clip-path: inset(0 0 55% 0);
    }

    85% {
      transform: translate(2px, 1px);
      opacity: 0.4;
    }

    86%,
    87% {
      transform: translate(1.5px, 0);
      opacity: 0.65;
      clip-path: inset(45% 0 0 0);
    }
  }

  @keyframes brand-bar-glitch {
    0%,
    41%,
    46%,
    82%,
    88%,
    100% {
      transform: none;
      opacity: 1;
      box-shadow:
        -2px 0 0 var(--gh-red),
        2px 0 0 var(--gh-cyan);
    }

    42%,
    84% {
      transform: translateX(-4px) scaleX(1.08);
      opacity: 0.75;
      box-shadow:
        -4px 0 0 var(--gh-red),
        4px 0 0 var(--gh-cyan);
    }

    43%,
    85% {
      transform: translateX(5px) scaleX(0.92);
      opacity: 1;
      box-shadow:
        3px 0 0 var(--gh-red),
        -3px 0 0 var(--gh-cyan);
    }

    44%,
    86% {
      transform: none;
      opacity: 0.45;
    }

    45%,
    87% {
      transform: none;
      opacity: 1;
      box-shadow:
        -2px 0 0 var(--gh-red),
        2px 0 0 var(--gh-cyan);
    }
  }

  /* 右侧功能入口竖栏：脱离文档流，不挤占居中品牌 */
  .glitch-hero__portals {
    --portal-peek: 2.35rem;
    position: absolute;
    z-index: 2;
    top: 50%;
    right: 0;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    width: min(12.5rem, 34vw);
    max-height: calc(100svh - 8.5rem);
    max-height: calc(100dvh - 8.5rem);
    overflow: visible;
    padding-block: 0.15rem;
    padding-inline-end: max(0.35rem, env(safe-area-inset-right));
  }

  .glitch-hero__portal {
    position: relative;
    display: grid;
    grid-template-columns: var(--portal-peek) auto 1fr;
    align-items: center;
    gap: 0.55rem 0.65rem;
    min-height: 3.1rem;
    padding: 0.75rem 0.85rem 0.75rem 0;
    border: 0;
    background:
      linear-gradient(
        120deg,
        rgba(244, 244, 242, 0.06),
        transparent 48%
      ),
      rgba(5, 5, 5, 0.32);
    color: var(--gh-fg) !important;
    opacity: 1 !important;
    text-decoration: none;
    clip-path: polygon(
      0 0,
      calc(100% - 10px) 0,
      100% 10px,
      100% 100%,
      10px 100%,
      0 calc(100% - 10px)
    );
    transition:
      background 220ms ease,
      transform 280ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 220ms ease;
  }

  /* 精确定位设备：默认滑出屏外，仅露出序号条 */
  @media (hover: hover) and (pointer: fine) {
    .glitch-hero__portal {
      transform: translateX(calc(100% - var(--portal-peek)));
      background: rgba(5, 5, 5, 0.42);
    }

    .glitch-hero__portal-corners,
    .glitch-hero__portal-scan,
    .glitch-hero__portal-icon,
    .glitch-hero__portal-label,
    .glitch-hero__portal-meta {
      opacity: 0;
      transition: opacity 180ms ease;
    }

    .glitch-hero__portal-index {
      justify-self: center;
      color: rgba(244, 244, 242, 0.72);
      transition: color 180ms ease;
    }

    .glitch-hero__portal:hover,
    .glitch-hero__portal:focus-visible {
      transform: translateX(0);
      background:
        linear-gradient(
          120deg,
          rgba(56, 189, 248, 0.14),
          transparent 58%
        ),
        rgba(5, 5, 5, 0.5);
      filter: drop-shadow(-1px 0 0 color-mix(in srgb, var(--gh-red) 55%, transparent))
        drop-shadow(1px 0 0 color-mix(in srgb, var(--gh-cyan) 55%, transparent));
      outline: none;
    }

    .glitch-hero__portal:hover .glitch-hero__portal-corners,
    .glitch-hero__portal:focus-visible .glitch-hero__portal-corners,
    .glitch-hero__portal:hover .glitch-hero__portal-icon,
    .glitch-hero__portal:focus-visible .glitch-hero__portal-icon,
    .glitch-hero__portal:hover .glitch-hero__portal-label,
    .glitch-hero__portal:focus-visible .glitch-hero__portal-label,
    .glitch-hero__portal:hover .glitch-hero__portal-meta,
    .glitch-hero__portal:focus-visible .glitch-hero__portal-meta {
      opacity: 1;
    }

    .glitch-hero__portal:hover .glitch-hero__portal-icon,
    .glitch-hero__portal:focus-visible .glitch-hero__portal-icon {
      opacity: 0.72;
    }

    .glitch-hero__portal:hover .glitch-hero__portal-meta,
    .glitch-hero__portal:focus-visible .glitch-hero__portal-meta {
      opacity: 1;
      color: rgba(244, 244, 242, 0.7);
    }

    .glitch-hero__portal:hover .glitch-hero__portal-scan,
    .glitch-hero__portal:focus-visible .glitch-hero__portal-scan {
      opacity: 1;
    }

    .glitch-hero__portal:hover .glitch-hero__portal-index,
    .glitch-hero__portal:focus-visible .glitch-hero__portal-index {
      color: rgba(244, 244, 242, 0.85);
    }
  }

  .glitch-hero__portal-corners {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .glitch-hero__portal-corners::before,
  .glitch-hero__portal-corners::after {
    content: '';
    position: absolute;
    width: 0.55rem;
    height: 0.55rem;
    border: 1px solid rgba(244, 244, 242, 0.5);
  }

  .glitch-hero__portal-corners::before {
    top: 0;
    left: 0;
    border-right: 0;
    border-bottom: 0;
  }

  .glitch-hero__portal-corners::after {
    right: 0;
    bottom: 0;
    border-top: 0;
    border-left: 0;
  }

  .glitch-hero__portal-scan {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 2px,
      rgba(255, 255, 255, 0.06) 2px,
      rgba(255, 255, 255, 0.06) 3px
    );
    transition: opacity 160ms ease;
  }

  .glitch-hero__portal-index {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--gh-muted);
  }

  .glitch-hero__portal-icon {
    font-size: 0.95rem;
    opacity: 0.72;
  }

  .glitch-hero__portal-corners,
  .glitch-hero__portal-scan,
  .glitch-hero__portal-label,
  .glitch-hero__portal-meta {
    transition: opacity 180ms ease;
  }

  .glitch-hero__portal-label {
    position: relative;
    justify-self: start;
    font-size: 0.84rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .glitch-hero__portal-label::before,
