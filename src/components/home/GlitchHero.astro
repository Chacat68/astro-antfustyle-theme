---
/**
 * 首页 Three.js 故障艺术展示台 + 功能入口
 * 中：品牌 + 页面入口；左下：社交；右下：搜索 / 语言 / 日夜 / RSS / 更新日志
 */
import Link from '~/components/base/Link.astro'
import SearchSwitch from '~/components/widgets/SearchSwitch.astro'
import LanguageSwitch from '~/components/widgets/LanguageSwitch.astro'
import ThemeSwitch from '~/components/widgets/ThemeSwitch.astro'
import RssLink from '~/components/widgets/RssLink.astro'
import { UI } from '~/config'
import { ensureTrailingSlash } from '~/utils/path'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { getLocale, useTranslations } from '~/i18n/translate'

const locale = getLocale(Astro.currentLocale)
const t = useTranslations(locale)

const line1 = t('home.glitch.line1')
const line2 = t('home.glitch.line2')

const navKeyByPath: Record<string, string> = {
  '/blog': 'nav.blog',
  '/projects': 'nav.projects',
  '/friends': 'nav.friends',
  '/photos': 'nav.photos',
  '/gallery': 'nav.gallery',
}

const iconByPath: Record<string, string> = {
  '/blog': 'i-ri-article-line',
  '/projects': 'i-ri-code-box-line',
  '/friends': 'i-ri-group-line',
  '/photos': 'i-ri-camera-ai-line',
  '/gallery': 'i-ri-palette-line',
}

const changelogHref = ensureTrailingSlash(
  getRelativeLocaleUrl(locale, 'changelog')
)

const portals = [
  {
    href: ensureTrailingSlash(getRelativeLocaleUrl(locale, 'about')),
    label: t('nav.about'),
    icon: 'i-ri-user-smile-line',
  },
  ...UI.internalNavs
    .filter((item) => item.path.replace(/\/+$/, '') !== '/changelog')
    .map((item) => {
      const path = item.path.replace(/\/+$/, '')
      const key = navKeyByPath[path]
      return {
        href: ensureTrailingSlash(
          getRelativeLocaleUrl(locale, path.replace(/^\//, ''))
        ),
        label: key ? t(key) : item.title,
        icon:
          ('icon' in item && item.icon) ||
          iconByPath[path] ||
          'i-ri-arrow-right-up-line',
      }
    }),
]
---

<section
  class="glitch-hero"
  id="glitch-hero"
  data-glitch-hero
  aria-label={t('home.glitch.aria')}
>
  <div class="glitch-hero__canvas" data-glitch-canvas aria-hidden="true"></div>

  <div class="glitch-hero__content">
    <header class="glitch-hero__brand">
      <div class="glitch-hero__frame" aria-hidden="true">
        <span class="glitch-hero__x"></span>
        <span class="glitch-hero__bar"></span>
      </div>
      <h1 class="glitch-hero__title" data-glitch-text>
        <span class="glitch-hero__line" data-text={line1}>{line1}</span>
        <span class="glitch-hero__line" data-text={line2}>{line2}</span>
      </h1>
    </header>

    <p class="glitch-hero__hint">{t('home.glitch.hold')}</p>

    <nav class="glitch-hero__portals" aria-label={t('home.glitch.portalsAria')}>
      {
        portals.map((item, index) => {
          const idx = String(index + 1).padStart(2, '0')
          return (
            <Link
              href={item.href}
              class="glitch-hero__portal"
              data-index={idx}
              style={`--portal-i: ${index}`}
            >
              <span class="glitch-hero__portal-corners" aria-hidden="true" />
              <span class="glitch-hero__portal-scan" aria-hidden="true" />
              <span class="glitch-hero__portal-index" aria-hidden="true">
                {idx}
              </span>
              <span
                class={`${item.icon} glitch-hero__portal-icon`}
                aria-hidden="true"
              />
              <span class="glitch-hero__portal-label" data-text={item.label}>
                {item.label}
              </span>
              <span class="glitch-hero__portal-meta" aria-hidden="true">
                SRC/{idx}
              </span>
            </Link>
          )
        })
      }
    </nav>
  </div>

  <nav class="glitch-hero__dock glitch-hero__dock--social" aria-label={t('home.glitch.socialsAria')}>
    <span class="glitch-hero__dock-tag" aria-hidden="true">SIG</span>
    {
      UI.socialLinks.map((item) => (
        <Link
          href={item.link}
          title={item.title}
          class="glitch-hero__dock-link"
          aria-label={item.title}
          external
        >
          {'icon' in item && <span class={item.icon} aria-hidden="true" />}
        </Link>
      ))
    }
  </nav>

  <div class="glitch-hero__dock glitch-hero__dock--tools" aria-label={t('home.glitch.toolsAria')}>
    <span class="glitch-hero__dock-tag" aria-hidden="true">SYS</span>
    <SearchSwitch />
    <LanguageSwitch />
    <ThemeSwitch />
    <RssLink class="glitch-hero__rss" />
    <Link
      href={changelogHref}
      class="glitch-hero__dock-link"
      title={t('nav.changelog')}
      aria-label={t('nav.changelog')}
    >
      <span class="i-ri-draft-line" aria-hidden="true"></span>
    </Link>
  </div>
</section>

<style>
  .glitch-hero {
    --gh-fg: #f4f4f2;
    --gh-muted: rgba(244, 244, 242, 0.5);
    --gh-red: #ff2a4a;
    --gh-cyan: #2ad4ff;

    position: relative;
    display: grid;
    place-items: center;
    width: 100%;
    min-height: 100svh;
    min-height: 100dvh;
    overflow: hidden;
    isolation: isolate;
    color: var(--gh-fg);
    background: #050505;
  }

  .glitch-hero__canvas {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
  }

  .glitch-hero__canvas :global(canvas) {
    display: block;
    width: 100% !important;
    height: 100% !important;
  }

  /* 底栏坞：左社交 / 右工具（不用 backdrop-filter，避免搜索面板错位） */
  .glitch-hero__dock {
    position: absolute;
    z-index: 2;
    bottom: max(1rem, env(safe-area-inset-bottom));
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgba(244, 244, 242, 0.18);
    background: rgba(5, 5, 5, 0.78);
    color: var(--gh-fg);
    clip-path: polygon(
      0 0,
      calc(100% - 8px) 0,
      100% 8px,
      100% 100%,
      8px 100%,
      0 calc(100% - 8px)
    );
  }

  .glitch-hero__dock--social {
    left: max(1rem, env(safe-area-inset-left));
  }

  .glitch-hero__dock--tools {
    right: max(1rem, env(safe-area-inset-right));
  }

  .glitch-hero__dock-tag {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    color: rgba(244, 244, 242, 0.35);
    padding-inline-end: 0.15rem;
    border-inline-end: 1px solid rgba(244, 244, 242, 0.16);
    margin-inline-end: 0.1rem;
  }

  .glitch-hero__dock :global(a),
  .glitch-hero__dock :global(button),
  .glitch-hero__dock-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--gh-fg) !important;
    opacity: 0.62 !important;
    font-size: 1.05rem;
    line-height: 1;
    transition: opacity 160ms ease;
  }

  .glitch-hero__dock :global(a:hover),
  .glitch-hero__dock :global(a:focus-visible),
  .glitch-hero__dock :global(button:hover),
  .glitch-hero__dock :global(button:focus-visible),
  .glitch-hero__dock-link:hover,
  .glitch-hero__dock-link:focus-visible {
    opacity: 1 !important;
  }

  .glitch-hero__dock :global(#theme-switch),
  .glitch-hero__dock :global(#search-switch) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .glitch-hero__rss {
    opacity: 0.62 !important;
  }

  .glitch-hero__content {
    position: relative;
    z-index: 1;
    display: grid;
    justify-items: center;
    gap: 1.5rem;
    width: min(100%, 36rem);
    padding:
      max(3.5rem, env(safe-area-inset-top))
      1.25rem
      max(6.5rem, calc(env(safe-area-inset-bottom) + 5rem));
  }

  .glitch-hero__brand {
    position: relative;
    display: grid;
    place-items: center;
    width: min(42vw, 240px);
    aspect-ratio: 1;
    border: 1px solid rgba(244, 244, 242, 0.85);
  }

  .glitch-hero__frame {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .glitch-hero__x::before,
  .glitch-hero__x::after {
    content: '';
    position: absolute;
    inset: 8% auto;
    left: 50%;
    width: 1px;
    height: 84%;
    background: rgba(244, 244, 242, 0.28);
  }

  .glitch-hero__x::before {
    transform: translateX(-50%) rotate(45deg);
  }

  .glitch-hero__x::after {
    transform: translateX(-50%) rotate(-45deg);
  }

  .glitch-hero__bar {
    position: absolute;
    left: 18%;
    right: 18%;
    bottom: 22%;
    height: 5px;
    background: var(--gh-fg);
    box-shadow:
      -2px 0 0 var(--gh-red),
      2px 0 0 var(--gh-cyan);
  }

  .glitch-hero__title {
    position: relative;
    z-index: 1;
    margin: 0;
    display: grid;
    gap: 0.05em;
    font-weight: 700;
    font-size: clamp(2.2rem, 7vw, 3.2rem);
    line-height: 0.95;
    letter-spacing: 0.08em;
    text-align: center;
    text-transform: uppercase;
  }

  .glitch-hero__line {
    position: relative;
    display: block;
  }

  .glitch-hero__line::before,
  .glitch-hero__line::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    overflow: hidden;
    opacity: 0.65;
    pointer-events: none;
  }

  .glitch-hero__line::before {
    color: var(--gh-red);
    transform: translate(-1.5px, 0);
    clip-path: inset(0 0 55% 0);
    mix-blend-mode: screen;
  }

  .glitch-hero__line::after {
    color: var(--gh-cyan);
    transform: translate(1.5px, 0);
    clip-path: inset(45% 0 0 0);
    mix-blend-mode: screen;
  }

  .glitch-hero__hint {
    margin: 0;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gh-muted);
  }

  .glitch-hero__portals {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem;
    width: min(100%, 32rem);
  }

  .glitch-hero__portal {
    position: relative;
    display: grid;
    grid-template-columns: auto auto 1fr;
    align-items: center;
    gap: 0.55rem 0.65rem;
    min-height: 3.1rem;
    padding: 0.75rem 0.85rem;
    border: 0;
    background:
      linear-gradient(
        120deg,
        rgba(244, 244, 242, 0.06),
        transparent 48%
      ),
      rgba(5, 5, 5, 0.32);
    color: var(--gh-fg) !important;
    opacity: 1 !important;
    text-decoration: none;
    clip-path: polygon(
      0 0,
      calc(100% - 10px) 0,
      100% 10px,
      100% 100%,
      10px 100%,
      0 calc(100% - 10px)
    );
    transition:
      background 160ms ease,
      transform 160ms ease,
      filter 160ms ease;
  }

  /* 奇数列轻微错位，形成信道阵列节奏 */
  .glitch-hero__portal:nth-child(odd) {
    transform: translateY(calc((var(--portal-i, 0) % 2) * 0.2rem));
  }

  .glitch-hero__portal:nth-child(even) {
    transform: translateY(calc(0.35rem - (var(--portal-i, 0) % 2) * 0.15rem));
  }

  .glitch-hero__portal-corners {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .glitch-hero__portal-corners::before,
  .glitch-hero__portal-corners::after {
    content: '';
    position: absolute;
    width: 0.55rem;
    height: 0.55rem;
    border: 1px solid rgba(244, 244, 242, 0.5);
  }

  .glitch-hero__portal-corners::before {
    top: 0;
    left: 0;
    border-right: 0;
    border-bottom: 0;
  }

  .glitch-hero__portal-corners::after {
    right: 0;
    bottom: 0;
    border-top: 0;
    border-left: 0;
  }

  .glitch-hero__portal-scan {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 2px,
      rgba(255, 255, 255, 0.06) 2px,
      rgba(255, 255, 255, 0.06) 3px
    );
    transition: opacity 160ms ease;
  }

  .glitch-hero__portal-index {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--gh-muted);
  }

  .glitch-hero__portal-icon {
    font-size: 0.95rem;
    opacity: 0.72;
  }

  .glitch-hero__portal-label {
    position: relative;
    justify-self: start;
    font-size: 0.84rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .glitch-hero__portal-label::before,
  .glitch-hero__portal-label::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
  }

  .glitch-hero__portal-label::before {
    color: var(--gh-red);
    transform: translate(-2px, 0);
  }

  .glitch-hero__portal-label::after {
    color: var(--gh-cyan);
    transform: translate(2px, 0);
  }

  .glitch-hero__portal-meta {
    position: absolute;
    right: 0.65rem;
    bottom: 0.35rem;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.52rem;
    letter-spacing: 0.1em;
    color: rgba(244, 244, 242, 0.22);
  }

  .glitch-hero__portal:hover,
  .glitch-hero__portal:focus-visible {
    background:
      linear-gradient(
        120deg,
        rgba(56, 189, 248, 0.14),
        transparent 58%
      ),
      rgba(5, 5, 5, 0.5);
    transform: translateY(-2px);
    filter: drop-shadow(-1px 0 0 color-mix(in srgb, var(--gh-red) 55%, transparent))
      drop-shadow(1px 0 0 color-mix(in srgb, var(--gh-cyan) 55%, transparent));
    outline: none;
  }

  .glitch-hero__portal:hover .glitch-hero__portal-scan,
  .glitch-hero__portal:focus-visible .glitch-hero__portal-scan {
    opacity: 1;
  }

  .glitch-hero__portal:hover .glitch-hero__portal-label::before,
  .glitch-hero__portal:focus-visible .glitch-hero__portal-label::before,
  .glitch-hero__portal:hover .glitch-hero__portal-label::after,
  .glitch-hero__portal:focus-visible .glitch-hero__portal-label::after {
    opacity: 0.7;
    mix-blend-mode: screen;
  }

  .glitch-hero__portal:hover .glitch-hero__portal-index,
  .glitch-hero__portal:focus-visible .glitch-hero__portal-index,
  .glitch-hero__portal:hover .glitch-hero__portal-meta,
  .glitch-hero__portal:focus-visible .glitch-hero__portal-meta {
    color: rgba(244, 244, 242, 0.7);
  }

  .glitch-hero__portal:hover .glitch-hero__portal-corners::before,
  .glitch-hero__portal:focus-visible .glitch-hero__portal-corners::before {
    border-color: var(--gh-cyan);
  }

  .glitch-hero__portal:hover .glitch-hero__portal-corners::after,
  .glitch-hero__portal:focus-visible .glitch-hero__portal-corners::after {
    border-color: var(--gh-red);
  }

  @media (max-width: 640px) {
    .glitch-hero__brand {
      width: min(52vw, 200px);
    }

    .glitch-hero__title {
      letter-spacing: 0.04em;
    }

    .glitch-hero__hint {
      letter-spacing: 0.14em;
    }

    .glitch-hero__content {
      width: min(100%, 22rem);
      gap: 1.25rem;
      padding-bottom: max(7.5rem, calc(env(safe-area-inset-bottom) + 6rem));
    }

    .glitch-hero__portals {
      grid-template-columns: 1fr;
      width: 100%;
    }

    .glitch-hero__portal,
    .glitch-hero__portal:nth-child(odd),
    .glitch-hero__portal:nth-child(even) {
      transform: none;
    }

    .glitch-hero__portal:hover,
    .glitch-hero__portal:focus-visible {
      transform: translateX(3px);
    }

    .glitch-hero__portal-meta {
      display: none;
    }

    .glitch-hero__portal-label {
      letter-spacing: 0.12em;
      font-size: 0.82rem;
    }

    .glitch-hero__dock {
      gap: 0.55rem;
      padding: 0.42rem 0.55rem;
    }

    .glitch-hero__dock-tag {
      display: none;
    }

    .glitch-hero__dock :global(a),
    .glitch-hero__dock :global(button),
    .glitch-hero__dock-link {
      font-size: 0.98rem;
    }
  }

  @media (max-width: 380px) {
    .glitch-hero__dock--social,
    .glitch-hero__dock--tools {
      max-width: calc(50vw - 0.85rem);
      flex-wrap: wrap;
      justify-content: center;
      row-gap: 0.35rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .glitch-hero__portal,
    .glitch-hero__portal:nth-child(odd),
    .glitch-hero__portal:nth-child(even) {
      transition: none;
      transform: none;
    }

    .glitch-hero__portal:hover,
    .glitch-hero__portal:focus-visible {
      transform: none;
      filter: none;
    }

    .glitch-hero__line::before,
    .glitch-hero__line::after {
      opacity: 0.35;
      transform: none;
    }
  }
</style>

<script>
  import type { GlitchHandle } from '~/components/backgrounds/glitch-engine'
  import { isDarkTheme } from '~/utils/theme'

  function initHeroGlitch() {
    const root = document.querySelector<HTMLElement>('[data-glitch-hero]')
    const canvasHost = root?.querySelector<HTMLElement>('[data-glitch-canvas]')
    if (!root || !canvasHost || root.dataset.ready === '1') return
    root.dataset.ready = '1'

    let handle: GlitchHandle | null = null
    let themeObserver: MutationObserver | null = null
    let idleHandle: number | null = null

    const mount = async () => {
      const { createGlitchEngine } = await import(
        '~/components/backgrounds/glitch-engine'
      )
      if (!root.isConnected || handle) return

      const reducedMotion = window.matchMedia(
        '(prefers-reduced-motion: reduce)'
      ).matches

      handle = createGlitchEngine(canvasHost, {
        mode: 'hero',
        reducedMotion,
        isDark: isDarkTheme(),
      })

      themeObserver = new MutationObserver(() => {
        handle?.setDark(isDarkTheme())
      })
      themeObserver.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class'],
      })

      // 悬停入口时加重故障
      root.querySelectorAll('.glitch-hero__portal').forEach((el) => {
        el.addEventListener('pointerenter', () => handle?.setIntensity(1.15))
        el.addEventListener('pointerleave', () => handle?.setIntensity(0.55))
      })
    }

    if (typeof requestIdleCallback === 'function') {
      idleHandle = requestIdleCallback(() => void mount(), { timeout: 1200 })
    } else {
      void mount()
    }

    document.addEventListener(
      'astro:before-swap',
      () => {
        if (idleHandle !== null) cancelIdleCallback(idleHandle)
        themeObserver?.disconnect()
        handle?.dispose()
        handle = null
        root.dataset.ready = '0'
      },
      { once: true }
    )
  }

  initHeroGlitch()
  document.addEventListener('astro:page-load', initHeroGlitch)
</script>
