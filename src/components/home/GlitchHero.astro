<script>
  import type { GlitchHandle } from '~/components/backgrounds/glitch-engine'
  import { isDarkTheme } from '~/utils/theme'

  function initHeroGlitch() {
    const root = document.querySelector<HTMLElement>('[data-glitch-hero]')
    const canvasHost = root?.querySelector<HTMLElement>('[data-glitch-canvas]')
    if (!root || !canvasHost || root.dataset.ready === '1') return
    root.dataset.ready = '1'

    let handle: GlitchHandle | null = null
    let themeObserver: MutationObserver | null = null
    let idleHandle: number | null = null

    const mount = async () => {
      const { createGlitchEngine } = await import(
        '~/components/backgrounds/glitch-engine'
      )
      if (!root.isConnected || handle) return

      const reducedMotion = window.matchMedia(
        '(prefers-reduced-motion: reduce)'
      ).matches

      handle = createGlitchEngine(canvasHost, {
        mode: 'hero',
        reducedMotion,
        isDark: isDarkTheme(),
      })

      themeObserver = new MutationObserver(() => {
        handle?.setDark(isDarkTheme())
      })
      themeObserver.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class'],
      })

      // 悬停入口时加重故障
      root.querySelectorAll('.glitch-hero__portal').forEach((el) => {
        el.addEventListener('pointerenter', () => handle?.setIntensity(1.15))
        el.addEventListener('pointerleave', () => handle?.setIntensity(0.55))
      })
    }

    if (typeof requestIdleCallback === 'function') {
      idleHandle = requestIdleCallback(() => void mount(), { timeout: 1200 })
    } else {
      void mount()
    }

    document.addEventListener(
      'astro:before-swap',
      () => {
        if (idleHandle !== null) cancelIdleCallback(idleHandle)
        themeObserver?.disconnect()
        handle?.dispose()
        handle = null
        root.dataset.ready = '0'
      },
      { once: true }
    )
  }

  initHeroGlitch()
  document.addEventListener('astro:page-load', initHeroGlitch)
</script>
