---
/**
 * 全站轻量故障艺术背景（纯 CSS）。
 * Three.js 仅保留给首页 GlitchHero 的 hero 舞台，避免内页多下载 ~130KB gzip JS。
 */
---

<div
  class="glitch-bg z--1 fixed inset-0 pointer-events-none print:hidden"
  aria-hidden="true"
>
  <div class="glitch-bg__glow"></div>
  <div class="glitch-bg__grid"></div>
  <div class="glitch-bg__noise"></div>
  <div class="glitch-bg__scan"></div>
  <div class="glitch-bg__vignette"></div>
</div>

<style>
  .glitch-bg {
    overflow: hidden;
    opacity: 0.55;
  }

  :root.dark .glitch-bg {
    opacity: 0.72;
  }

  .glitch-bg__glow {
    position: absolute;
    inset: -20%;
    background:
      radial-gradient(
        ellipse 55% 40% at 18% 22%,
        color-mix(in srgb, var(--c-accent) 18%, transparent),
        transparent 70%
      ),
      radial-gradient(
        ellipse 45% 35% at 82% 78%,
        color-mix(in srgb, var(--c-glitch-cyan) 12%, transparent),
        transparent 72%
      ),
      radial-gradient(
        ellipse 30% 25% at 70% 18%,
        color-mix(in srgb, var(--c-glitch-red) 8%, transparent),
        transparent 70%
      );
    animation: glitch-bg-drift 28s var(--ease-out, ease) infinite alternate;
  }

  .glitch-bg__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(
        to right,
        color-mix(in srgb, var(--c-hud-grid) 55%, transparent) 1px,
        transparent 1px
      ),
      linear-gradient(
        to bottom,
        color-mix(in srgb, var(--c-hud-grid) 55%, transparent) 1px,
        transparent 1px
      );
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 20%, transparent 75%);
    opacity: 0.35;
  }

  .glitch-bg__noise {
    position: absolute;
    inset: -10%;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.55'/%3E%3C/svg%3E");
    background-size: 180px 180px;
    mix-blend-mode: soft-light;
    opacity: 0.22;
    animation: glitch-bg-noise 1.2s steps(2) infinite;
  }

  .glitch-bg__scan {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 2px,
      color-mix(in srgb, var(--c-accent) 4%, transparent) 2px,
      color-mix(in srgb, var(--c-accent) 4%, transparent) 3px
    );
    opacity: 0.4;
    animation: glitch-bg-scan 9s linear infinite;
  }

  .glitch-bg__vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 75% 65% at 50% 45%,
      transparent 40%,
      color-mix(in srgb, var(--c-bg) 55%, transparent) 100%
    );
  }

  @keyframes glitch-bg-drift {
    from {
      transform: translate3d(-1.5%, -1%, 0) scale(1.02);
    }
    to {
      transform: translate3d(1.5%, 1.2%, 0) scale(1.06);
    }
  }

  @keyframes glitch-bg-scan {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(12px);
    }
  }

  @keyframes glitch-bg-noise {
    0%,
    100% {
      transform: translate(0, 0);
      opacity: 0.18;
    }
    50% {
      transform: translate(-1.5%, 1%);
      opacity: 0.28;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .glitch-bg__glow,
    .glitch-bg__noise,
    .glitch-bg__scan {
      animation: none;
    }

    .glitch-bg__noise {
      opacity: 0.16;
    }
  }
</style>
