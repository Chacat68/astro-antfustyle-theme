---
// Wave background animation - 多条正弦波叠加效果
---

<bg-wave
  class="z--1 fixed top-0 bottom-0 left-0 right-0 pointer-events-none print:hidden"
>
</bg-wave>

<script>
  import type { default as P5Instance } from 'p5'

  class BgWaveElement extends HTMLElement {
    p5Instance: P5Instance | null = null

    async connectedCallback() {
      if (this.p5Instance) return

      const { default: p5 } = await import('p5')
      if (!this.isConnected) return

      const sketch = (p: P5Instance) => {
        const WAVE_COUNT = 7
        const AMPLITUDE_BASE = 35
        const SPEED = 0.018
        // Vertical spread per wave layer (larger = more spread)
        const V_SPREAD = 48

        const width = window.innerWidth
        const height = window.innerHeight

        let time = 0

        p.setup = () => {
          p.createCanvas(width, height)
          p.noFill()
        }

        p.draw = () => {
          p.clear()
          time += SPEED

          const isDark = document.documentElement.classList.contains('dark')

          for (let w = 0; w < WAVE_COUNT; w++) {
            // Front waves are more opaque and thicker → depth effect
            const t = w / (WAVE_COUNT - 1) // 0 (back) → 1 (front)
            const alpha = 12 + t * 32
            const strokeW = 0.6 + t * 1.4

            const color = isDark
              ? p.color(96, 165, 250, alpha)
              : p.color(37, 99, 235, alpha)

            p.stroke(color)
            p.strokeWeight(strokeW)

            p.beginShape()
            for (let x = 0; x <= width; x += 4) {
              const amplitude = AMPLITUDE_BASE + w * 12
              const frequency = 0.004 + w * 0.0018
              const phase = w * 0.7

              const y =
                height / 2 +
                Math.sin(x * frequency + time + phase) * amplitude +
                Math.sin(x * frequency * 0.5 + time * 0.65 + phase) *
                  amplitude *
                  0.45 +
                Math.cos(x * frequency * 1.3 + time * 0.4 + phase) *
                  amplitude *
                  0.2

              p.vertex(x, y + (w - WAVE_COUNT / 2) * V_SPREAD)
            }
            p.endShape()
          }
        }
      }

      this.p5Instance = new p5(sketch, this)
    }

    disconnectedCallback() {
      if (this.p5Instance) {
        this.p5Instance.remove()
        this.p5Instance = null
      }
    }
  }

  if (!customElements.get('bg-wave')) {
    customElements.define('bg-wave', BgWaveElement)
  }
</script>
