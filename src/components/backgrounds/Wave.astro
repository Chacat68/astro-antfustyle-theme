---
// Wave background — 纯 SVG + CSS 正弦波，替代 p5 实现以避免首屏加载 ~1MB JS
---

<div
  class="wave-bg z--1 fixed inset-0 pointer-events-none print:hidden"
  aria-hidden="true"
>
  {
    Array.from({ length: 7 }, (_, index) => {
      const depth = index / 6
      const opacity = 0.05 + depth * 0.12
      const strokeWidth = 0.6 + depth * 1.4
      const yOffset = (index - 3) * 48
      const duration = 18 + index * 3
      const delay = index * -2.5

      return (
        <svg
          class="wave-bg__layer"
          style={{
            '--wave-opacity': opacity,
            '--wave-stroke': strokeWidth,
            '--wave-y': `${yOffset}px`,
            '--wave-duration': `${duration}s`,
            '--wave-delay': `${delay}s`,
          }}
          preserveAspectRatio="none"
          viewBox="0 0 2880 900"
        >
          <path
            class="wave-bg__path"
            d="M0,450 C120,410 240,490 360,450 S600,410 720,450 S960,490 1080,450 S1320,410 1440,450 S1680,490 1800,450 S2040,410 2160,450 S2400,490 2520,450 S2760,410 2880,450"
          />
        </svg>
      )
    })
  }
</div>

<style>
  .wave-bg {
    overflow: hidden;

    /* 与站点 accent 天空蓝同色系 */
    --wave-color: rgb(8 145 178);
  }

  :global(:root.dark) .wave-bg {
    --wave-color: rgb(34 211 238);
  }

  .wave-bg__layer {
    position: absolute;
    inset: 0;

    width: 200%;
    height: 100%;

    transform: translateY(var(--wave-y, 0));

    animation: wave-drift var(--wave-duration, 20s) linear infinite;
    animation-delay: var(--wave-delay, 0s);
  }

  .wave-bg__path {
    fill: none;
    stroke: var(--wave-color);
    stroke-opacity: var(--wave-opacity, 0.1);
    stroke-width: var(--wave-stroke, 1);
    vector-effect: non-scaling-stroke;
  }

  @keyframes wave-drift {
    from {
      transform: translateX(0) translateY(var(--wave-y, 0));
    }

    to {
      transform: translateX(-50%) translateY(var(--wave-y, 0));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wave-bg__layer {
      animation: none;
      width: 100%;
    }
  }
</style>
