---
import Glitch from '~/components/backgrounds/Glitch.astro'

import type { BgType } from '~/types'

interface Props {
  type: BgType
}

const { type } = Astro.props
---

{/* 全站统一故障艺术背景；保留 type 分支以便未来扩展强度档位 */}
{(type === 'glitch' ||
  type === 'plum' ||
  type === 'dot' ||
  type === 'rose' ||
  type === 'particle' ||
  type === 'wave' ||
  type === 'constellation') && <Glitch />}
