---
import Link from '~/components/base/Link.astro'
import { UI } from '~/config'

export interface GroupItemData {
    id: string;
    link: string;
    desc: string;
    icon?: string;
    avatar?: string;
}

interface Props {
  items: GroupItemData[]
}

const { items } = Astro.props
const { maxGroupColumns, showGroupItemColorOnHover } = UI.groupView
---

<div
  class={`grid grid-cols-[repeat(auto-fill,minmax(min(100%,260px),1fr))] gap-3
    py-8 mx-auto w-full lt-lgp:max-w-[712px]!`}
  style={`max-width: min(100%, calc(280px * ${maxGroupColumns} + ${maxGroupColumns - 1} * 0.75rem));`}
>
  {
    items.map((item) => (
      <Link
        class={`group-item-link group relative flex items-center
          px-3.5 pt-2 pb-3.5 rounded-[var(--c-radius)]
          bg-transparent
          text-4.4 transition-all duration-300`}
        href={item.link}
        aria-hidden={true}
        external={true}
      >
        <div class="pt-2 pr-5">
          {item.avatar ? (
            <img
              src={item.avatar}
              alt={item.id}
              class="w-12 h-12 rounded-full object-cover op-80 group-hover:op-100 transition-opacity duration-300"
            />
          ) : (
            <div
              class={`group-hover:data-show-color:saturate-100 op-50 saturate-0 leading-9 text-7.5 ${item.icon || 'i-ph-user-circle-duotone'}`}
              data-show-color={showGroupItemColorOnHover ? '' : undefined}
            />
          )}
        </div>
        <div class="flex-auto">
          <div>{item.id}</div>
          <div class="op-50 text-sm font-normal font-mono tracking-wide">{item.desc}</div>
        </div>
      </Link>
    ))
  }
</div>

<style>
  .group-item-link {
    border: 1px solid transparent;
  }

  .group-item-link:hover,
  .group-item-link:focus-visible {
    border-color: color-mix(in srgb, var(--c-accent) 28%, var(--c-border));
    background: var(--c-accent-soft);
  }
</style>

