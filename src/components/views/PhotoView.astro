---
import Loader from '~/components/widgets/Loader.astro'
import ImageViewer from '~/components/widgets/ImageViewer.astro'
import { getLocale, useTranslations } from '~/i18n/translate'

import { hash as defaultPhotosHash } from '~/pages/photos/photos.[hash].json'

interface Props {
  gap?: number
  minPhotoWidth?: number
  maxPhotoWidth?: number
  batchSize?: number
  layout?: 'masonry' | 'square'
  masonryStrategy?: 'sequential' | 'balanced'
  /** JSON 路径前缀（不含 `.${hash}.json`），默认 `/photos/photos` */
  jsonBase?: string
  /** 与预构建 JSON 对应的短 hash；默认使用相册数据 */
  contentHash?: string
  /** localStorage 布局键；多画廊时勿与相册共用同一键 */
  layoutStorageKey?: string
  /** Text displayed when the current gallery has no entries. */
  emptyText?: string
  /** Text displayed when the gallery JSON cannot be loaded. */
  errorText?: string
  /** 是否展示作品类型筛选（全部 / 角色 / 场景），依赖 JSON 条目的可选 `kind` 字段 */
  kindFilter?: boolean
  /** 筛选为「全部」时的标签文案 */
  filterAllLabel?: string
  /** 筛选为「角色」时的标签文案 */
  filterCharacterLabel?: string
  /** 筛选为「场景」时的标签文案 */
  filterSceneLabel?: string
  /** 筛选控件 `role="tablist"` 的无障碍名称 */
  filterAriaLabel?: string
  /** 当前筛选下无作品时的提示（例如仅「角色」下暂无条目） */
  emptyFilterText?: string
}

const {
  gap = 16,
  minPhotoWidth = 240,
  maxPhotoWidth = 1000,
  batchSize = 15,
  layout = 'masonry',
  masonryStrategy = 'sequential',
  jsonBase = '/photos/photos',
  contentHash = defaultPhotosHash,
  layoutStorageKey = 'photo-layout',
  emptyText,
  errorText,
  kindFilter = false,
  filterAllLabel,
  filterCharacterLabel,
  filterSceneLabel,
  filterAriaLabel,
  emptyFilterText,
} = Astro.props as Props

const locale = getLocale(Astro.currentLocale)
const t = useTranslations(locale)
const resolvedEmptyText = emptyText ?? t('photo.empty')
const resolvedErrorText = errorText ?? t('photo.error')
const resolvedFilterAll = filterAllLabel ?? t('page.gallery.filterAll')
const resolvedFilterCharacter =
  filterCharacterLabel ?? t('page.gallery.filterCharacter')
const resolvedFilterScene = filterSceneLabel ?? t('page.gallery.filterScene')
const resolvedFilterAria = filterAriaLabel ?? t('page.gallery.filterAria')
const resolvedEmptyFilter =
  emptyFilterText ?? t('page.gallery.emptyFilter')
---

<div class="mx-20 lt-lgp:mx-10 lt-md:mx-1">
  <photo-view
    data-hash={contentHash}
    data-json-base={jsonBase}
    data-layout-storage-key={layoutStorageKey}
    data-gap={gap}
    data-min-photo-width={minPhotoWidth}
    data-max-photo-width={maxPhotoWidth}
    data-batch-size={batchSize}
    data-layout={layout}
    data-masonry-strategy={layout === 'masonry' ? masonryStrategy : undefined}
    data-empty-text={resolvedEmptyText}
    data-error-text={resolvedErrorText}
    data-kind-filter={kindFilter ? 'true' : undefined}
    data-empty-filter-text={kindFilter ? resolvedEmptyFilter : undefined}
    data-tag-character-label={kindFilter ? resolvedFilterCharacter : undefined}
    data-tag-scene-label={kindFilter ? resolvedFilterScene : undefined}
    class="photo-view block relative w-full"
  >
    {
      kindFilter && (
        <div
          class="kind-filter-wrap mb-6 flex flex-wrap justify-center gap-2 lt-md:mb-4"
          role="tablist"
          aria-label={resolvedFilterAria}
        >
          <button
            type="button"
            role="tab"
            aria-selected="true"
            data-kind="all"
            class="kind-filter-btn rounded-full border border-#8884 bg-transparent px-4 py-1.5 text-sm op-80 transition-colors hover:(op-100 border-primary) aria-selected:(border-primary bg-primary/12 op-100 font-medium)"
          >
            {resolvedFilterAll}
          </button>
          <button
            type="button"
            role="tab"
            aria-selected="false"
            data-kind="character"
            class="kind-filter-btn rounded-full border border-#8884 bg-transparent px-4 py-1.5 text-sm op-80 transition-colors hover:(op-100 border-primary) aria-selected:(border-primary bg-primary/12 op-100 font-medium)"
          >
            {resolvedFilterCharacter}
          </button>
          <button
            type="button"
            role="tab"
            aria-selected="false"
            data-kind="scene"
            class="kind-filter-btn rounded-full border border-#8884 bg-transparent px-4 py-1.5 text-sm op-80 transition-colors hover:(op-100 border-primary) aria-selected:(border-primary bg-primary/12 op-100 font-medium)"
          >
            {resolvedFilterScene}
          </button>
        </div>
      )
    }
    <div class="photo-container"></div>
    <p class="photo-empty-state hidden" role="status">
      {resolvedEmptyText}
    </p>
    <button
      class="photo-layout-toggle z-50 fixed left-5 bottom-6
        flex items-center justify-center w-10 h-10 rounded-full
        op-30 op-transition lt-lgp:(op-50! bg-#8883 dark:bg-#8886)
        hover:(op-100! bg-#8883) print:hidden"
      title={t('a11y.layoutToggle')}
    >
      <div u-i-ri-layout-masonry-line class="icon-masonry hidden"></div>
      <div u-i-ri-layout-grid-2-line class="icon-grid hidden"></div>
    </button>
  </photo-view>
  <Loader class="photo-loader" />
  <ImageViewer
    selector=".photo-container"
    options={{ url: 'data-origin' }}
    asyncInsert={true}
    tabFocus={true}
  />
</div>

<script>
  import type {
    PhotoGalleryItem,
    PhotoGalleryKind,
  } from '~/types/photo-gallery'

  type GalleryKindFilter = 'all' | PhotoGalleryKind

  class PhotoView extends HTMLElement {
    #initialized = false
    #isMasonry = this.dataset.layout === 'masonry'
    #masonryStrategy = this.dataset.masonryStrategy || 'sequential'

    #gap = parseInt(this.dataset.gap || '16', 10)
    #minPhotoWidth = parseInt(this.dataset.minPhotoWidth || '240', 10)
    #maxPhotoWidth = parseInt(this.dataset.maxPhotoWidth || '1000', 10)
    #batchSize = parseInt(this.dataset.batchSize || '15', 10)

    #columns = 0
    #colWidth = 0
    #containerWidth = 0
    #colHeights: number[] = []

    #currentIndex = 0
    #isLoading = false
    #allLoaded = false
    #rawItems: PhotoGalleryItem[] = []
    #visibleItems: PhotoGalleryItem[] = []
    #activeKind: GalleryKindFilter = 'all'

    #ticking = false
    #distanceToBottom = window.innerHeight * 0.6

    #loader: HTMLElement | null = null
    #container: HTMLElement | null = null
    #emptyState: HTMLElement | null = null
    #button: HTMLButtonElement | null = null
    #resizeObserver: ResizeObserver | null = null
    #debounceTimeout: ReturnType<typeof setTimeout> | null = null

    #kindFilterEnabled = () => this.dataset.kindFilter === 'true'

    #kindChipLabel(kind: PhotoGalleryKind): string {
      if (kind === 'character') {
        return this.dataset.tagCharacterLabel || 'Character'
      }
      return this.dataset.tagSceneLabel || 'Scene'
    }

    /** 从地址栏 ?kind= 读取初始筛选（与浏览器前进/后退同步） */
    #readKindFromUrl = () => {
      if (!this.#kindFilterEnabled()) return
      const u = new URL(window.location.href)
      const p = u.searchParams.get('kind')
      if (p === 'character' || p === 'scene') {
        this.#activeKind = p
        return
      }
      if (p === 'all') {
        this.#activeKind = 'all'
        return
      }
      this.#activeKind = 'all'
      if (p !== null && p !== '') this.#syncKindToUrl()
    }

    #syncKindToUrl = () => {
      if (!this.#kindFilterEnabled()) return
      const u = new URL(window.location.href)
      if (this.#activeKind === 'all') u.searchParams.delete('kind')
      else u.searchParams.set('kind', this.#activeKind)
      const search = u.searchParams.toString()
      const next = `${u.pathname}${search ? `?${search}` : ''}${u.hash}`
      const cur = `${window.location.pathname}${window.location.search}${window.location.hash}`
      if (next !== cur) history.replaceState(null, '', next)
    }

    #onPopState = () => {
      if (!this.#kindFilterEnabled()) return
      this.#readKindFromUrl()
      this.#syncFilterTabAria()
      if (this.#container) {
        this.#container.innerHTML = ''
        this.#container.style.cssText = ''
      }
      if (this.#loader) this.#loader.style.display = ''
      this.style.height = this.#isMasonry ? '0' : 'auto'
      this.#currentIndex = 0
      this.#isLoading = false
      this.#allLoaded = false
      this.#colHeights = []
      this.#recomputeVisible()
      if (this.#rawItems.length === 0) {
        this.#showEmptyState('empty')
        return
      }
      if (this.#visibleItems.length === 0) {
        this.#showEmptyState('filter')
        return
      }
      this.#hideEmptyState()
      this.#buildLayout()
      this.#handleWindowScroll()
    }

    /** 在图片上追加可点击的类型角标（点击后筛选同类型作品） */
    #appendKindChip(fig: HTMLElement, item: PhotoGalleryItem) {
      if (!this.#kindFilterEnabled() || !item.kind) return
      const kind = item.kind
      const btn = document.createElement('button')
      btn.type = 'button'
      btn.className = 'photo-kind-chip'
      btn.dataset.kind = kind
      btn.textContent = this.#kindChipLabel(kind)
      btn.title = this.#kindChipLabel(kind)
      btn.addEventListener('click', (ev) => {
        ev.preventDefault()
        ev.stopPropagation()
        this.#applyKindFilter(kind)
      })
      btn.addEventListener('mousedown', (ev) => {
        ev.stopPropagation()
      })
      fig.appendChild(btn)
    }

    #recomputeVisible = () => {
      if (!this.#kindFilterEnabled()) {
        this.#visibleItems = this.#rawItems
        return
      }
      if (this.#activeKind === 'all') {
        this.#visibleItems = this.#rawItems
      } else {
        this.#visibleItems = this.#rawItems.filter(
          (i) => i.kind === this.#activeKind
        )
      }
    }

    #hideEmptyState = () => {
      if (this.#emptyState) this.#emptyState.classList.add('hidden')
      if (this.#button) this.#button.style.display = ''
    }

    #syncFilterTabAria = () => {
      const ak =
        this.#activeKind === 'all' ? 'all' : this.#activeKind
      this.querySelectorAll('.kind-filter-btn').forEach((el) => {
        const b = el as HTMLButtonElement
        const k = b.dataset.kind || ''
        b.setAttribute('aria-selected', k === ak ? 'true' : 'false')
      })
    }

    #parseKindTabValue = (k: string | undefined): GalleryKindFilter | null => {
      if (!k) return null
      if (k === 'all') return 'all'
      if (k === 'character' || k === 'scene') return k
      return null
    }

    #handleKindFilterClick = (ev: Event) => {
      const btn = ev.currentTarget as HTMLButtonElement
      const next = this.#parseKindTabValue(btn.dataset.kind)
      if (next !== null) this.#applyKindFilter(next)
    }

    /** 切换筛选：更新地址栏、顶部标签状态并重绘列表 */
    #applyKindFilter = (next: GalleryKindFilter) => {
      if (!this.#kindFilterEnabled()) return
      if (next === this.#activeKind) return

      this.#activeKind = next
      this.#syncKindToUrl()
      this.#syncFilterTabAria()

      if (this.#container) {
        this.#container.innerHTML = ''
        this.#container.style.cssText = ''
      }
      if (this.#loader) this.#loader.style.display = ''
      this.style.height = this.#isMasonry ? '0' : 'auto'

      this.#currentIndex = 0
      this.#isLoading = false
      this.#allLoaded = false
      this.#colHeights = []

      this.#recomputeVisible()

      if (this.#visibleItems.length === 0) {
        this.#showEmptyState('filter')
        return
      }

      this.#hideEmptyState()
      this.#buildLayout()
      this.#handleWindowScroll()
    }

    async connectedCallback() {
      if (this.#initialized) return
      this.#initialized = true
      this.#container = this.querySelector('.photo-container')
      this.#emptyState = this.querySelector('.photo-empty-state')
      this.#button = this.querySelector('.photo-layout-toggle')
      this.#loader = document.querySelector('.photo-loader')

      const didLoad = await this.#fetchData()
      this.#getLayout()
      if (!didLoad) {
        this.#showEmptyState('error')
        return
      }
      if (this.#rawItems.length === 0) {
        this.#showEmptyState('empty')
        return
      }

      if (this.#kindFilterEnabled()) {
        this.#readKindFromUrl()
        this.#recomputeVisible()
        this.#syncFilterTabAria()
        this.querySelectorAll('.kind-filter-btn').forEach((el) => {
          el.addEventListener('click', this.#handleKindFilterClick)
        })
        window.addEventListener('popstate', this.#onPopState)
      } else {
        this.#recomputeVisible()
      }

      if (this.#visibleItems.length === 0) {
        this.#showEmptyState('filter')
        return
      }

      this.#buildLayout()
      this.#handleWindowScroll()

      window.addEventListener('scroll', this.#handleWindowScroll, {
        passive: true,
      })

      this.#resizeObserver = new ResizeObserver(this.#handleResize)
      this.#resizeObserver.observe(this)

      this.#button?.addEventListener('click', this.#handleClickToggle)

      this.#container?.addEventListener('keydown', this.#handleKeyOpen)
    }

    disconnectedCallback() {
      window.removeEventListener('scroll', this.#handleWindowScroll)

      if (this.#kindFilterEnabled()) {
        this.querySelectorAll('.kind-filter-btn').forEach((el) => {
          el.removeEventListener('click', this.#handleKindFilterClick)
        })
        window.removeEventListener('popstate', this.#onPopState)
      }

      if (this.#resizeObserver) {
        this.#resizeObserver.disconnect()
        this.#resizeObserver = null
      }

      if (this.#debounceTimeout) {
        clearTimeout(this.#debounceTimeout)
        this.#debounceTimeout = null
      }

      if (this.#button) {
        this.#button.removeEventListener('click', this.#handleClickToggle)
        this.#button = null
      }

      if (this.#container) {
        this.#container.removeEventListener('keydown', this.#handleKeyOpen)
        this.#container = null
      }

      this.#emptyState = null
      this.#initialized = false
    }

    #fetchData = async () => {
      try {
        const base = this.dataset.jsonBase || '/photos/photos'
        const res = await fetch(`${base}.${this.dataset.hash}.json`)
        if (!res.ok) {
          throw new Error(`HTTP ${res.status} while loading ${res.url}`)
        }
        const [_v, data] = (await res.json()) as [string, PhotoGalleryItem[]]
        this.#rawItems = Array.isArray(data) ? data : []
        return true
      } catch (err) {
        console.error('[PhotoView] fetch error:', err)
        this.#rawItems = []
        this.#visibleItems = []
        return false
      }
    }

    #showEmptyState = (type: 'empty' | 'error' | 'filter') => {
      if (this.#loader) this.#loader.style.display = 'none'
      if (this.#button) this.#button.style.display = 'none'
      if (this.#emptyState) {
        if (type === 'error') {
          this.#emptyState.textContent =
            this.dataset.errorText || 'Failed to load images.'
        } else if (type === 'filter') {
          this.#emptyState.textContent =
            this.dataset.emptyFilterText ||
            this.dataset.emptyText ||
            'No images in this category.'
        } else {
          this.#emptyState.textContent =
            this.dataset.emptyText || 'No images yet.'
        }
        this.#emptyState.classList.remove('hidden')
      }
      this.style.height = 'auto'
      this.#allLoaded = true
      this.#isLoading = false
    }

    #layoutStorageKey = () => this.dataset.layoutStorageKey || 'photo-layout'

    #getLayout = () => {
      const key = this.#layoutStorageKey()
      if (localStorage.getItem(key)) {
        this.#isMasonry = localStorage.getItem(key) === 'masonry'
      } else {
        this.#isMasonry = this.dataset.layout === 'masonry'
        localStorage.setItem(key, this.#isMasonry ? 'masonry' : 'square')
      }

      this.dataset.layout = this.#isMasonry ? 'masonry' : 'square'
    }

    #buildLayout = () => {
      if (this.#isMasonry) {
        this.#getMasonryParams()
        this.#renderMasonry()
        this.#isLoading = false
      } else {
        this.#getGridParams()
        this.#renderGrid()
        this.#isLoading = false
      }
    }

    #getMasonryParams = () => {
      this.#containerWidth = this.offsetWidth

      this.#columns = Math.floor(this.#containerWidth / this.#minPhotoWidth)
      this.#columns = Math.max(
        1,
        Math.min(this.#columns, this.#visibleItems.length)
      )

      const totalGap = this.#gap * (this.#columns - 1)
      this.#colWidth = (this.#containerWidth - totalGap) / this.#columns
      this.#colWidth = Math.min(this.#colWidth, this.#maxPhotoWidth)
      this.#container?.style.setProperty('--photo-width', `${this.#colWidth}px`)

      this.#colHeights = new Array(this.#columns).fill(0)
    }

    #calcMasonryTranslate = (
      idx: number
    ): { col: number; left: number; top: number } => {
      const col =
        this.#masonryStrategy === 'sequential'
          ? idx % this.#columns
          : this.#colHeights.indexOf(Math.min(...this.#colHeights))
      const top = this.#colHeights[col]
      const left = col * (this.#colWidth + this.#gap)
      return { col, left, top }
    }

    #renderMasonry = () => {
      const startIndex = this.#currentIndex * this.#batchSize
      const endIndex = startIndex + this.#batchSize
      const items = this.#visibleItems.slice(startIndex, endIndex)

      if (items.length === 0) {
        this.#isLoading = false
        this.#allLoaded = true
        return
      }

      const fragment = document.createDocumentFragment()
      let idx = startIndex
      for (const item of items) {
        const aspect = item.aspectRatio
        const height = this.#colWidth / aspect
        const { col, left, top } = this.#calcMasonryTranslate(idx)

        const fig = document.createElement('figure')
        fig.className = 'photo-figure'
        fig.dataset.aspectRatio = aspect.toString()
        fig.setAttribute('role', 'button')
        fig.setAttribute('tabindex', '0')
        fig.setAttribute('aria-label', 'Open viewer')
        fig.style.setProperty('--photo-top', top.toString() + 'px')
        fig.style.setProperty('--photo-left', left.toString() + 'px')
        fig.style.setProperty('--photo-height', `${height}px`)
        fig.style.setProperty('--photo-placeholder', `url(${item.placeholder})`)

        const img = document.createElement('img')
        img.src = item.thumbnail
        img.alt = item.desc
        img.dataset.origin = item.src
        img.addEventListener(
          'load',
          function (this: HTMLImageElement) {
            this.style.setProperty('--photo-opacity', '1')
          },
          { once: true }
        )
        fig.appendChild(img)

        this.#appendKindChip(fig, item)

        if (item.desc) {
          const figcaption = document.createElement('figcaption')
          figcaption.textContent = item.desc
          figcaption.setAttribute('aria-hidden', 'true')
          fig.appendChild(figcaption)
        }

        this.#colHeights[col] += this.#colWidth / aspect + this.#gap
        fragment.appendChild(fig)
        idx++
      }
      if (this.#loader) this.#loader.style.display = 'none'
      this.style.height = `${Math.max(...this.#colHeights)}px`
      this.#container?.appendChild(fragment)
      this.#currentIndex++
    }

    #getGridParams = () => {
      this.#container?.style.setProperty(
        '--min-photo-width',
        `${this.#minPhotoWidth}px`
      )
      this.#container?.style.setProperty('--photo-gap', `${this.#gap}px`)
    }

    #renderGrid = () => {
      const startIndex = this.#currentIndex * this.#batchSize
      const endIndex = startIndex + this.#batchSize
      const items = this.#visibleItems.slice(startIndex, endIndex)

      if (items.length === 0) {
        this.#isLoading = false
        this.#allLoaded = true
        return
      }

      const fragment = document.createDocumentFragment()
      for (const item of items) {
        const fig = document.createElement('figure')
        fig.className = 'photo-figure'
        fig.setAttribute('role', 'button')
        fig.setAttribute('tabindex', '0')
        fig.setAttribute('aria-label', 'Open viewer')
        fig.style.setProperty('--photo-placeholder', `url(${item.placeholder})`)

        const img = document.createElement('img')
        img.src = item.thumbnail
        img.alt = item.desc
        img.dataset.origin = item.src
        img.addEventListener(
          'load',
          function (this: HTMLImageElement) {
            this.style.opacity = '1'
          },
          { once: true }
        )
        fig.appendChild(img)

        this.#appendKindChip(fig, item)

        if (item.desc) {
          const figcaption = document.createElement('figcaption')
          figcaption.textContent = item.desc
          figcaption.setAttribute('aria-hidden', 'true')
          fig.appendChild(figcaption)
        }

        fragment.appendChild(fig)
      }
      if (this.#loader) this.#loader.style.display = 'none'
      this.#container?.appendChild(fragment)
      this.#currentIndex++
    }

    #updateMasonryLayout = () => {
      if (this.#containerWidth === this.offsetWidth) return
      this.#getMasonryParams()

      const figs = Array.from(
        this.querySelectorAll('.photo-figure')
      ) as HTMLElement[]
      for (let idx = 0; idx < figs.length; idx++) {
        const fig = figs[idx]
        const { col, left, top } = this.#calcMasonryTranslate(idx)
        const ratio = parseFloat(fig.dataset.aspectRatio!)

        fig.style.setProperty('--photo-left', left.toString() + 'px')
        fig.style.setProperty('--photo-top', top.toString() + 'px')
        fig.style.setProperty('--photo-height', `${this.#colWidth / ratio}px`)

        this.#colHeights[col] += this.#colWidth / ratio + this.#gap
      }

      this.style.height = `${Math.max(...this.#colHeights)}px`
    }

    #handleScroll = () => {
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop
      const windowHeight = window.innerHeight
      const documentHeight = document.documentElement.scrollHeight
      const isNearBottom =
        documentHeight - (scrollTop + windowHeight) <= this.#distanceToBottom

      if (isNearBottom) {
        this.#isLoading = true
        this.#isMasonry ? this.#renderMasonry() : this.#renderGrid()
        this.#isLoading = false
      }
    }

    #handleWindowScroll = () => {
      if (!this.#ticking && !this.#isLoading && !this.#allLoaded) {
        requestAnimationFrame(() => {
          this.#handleScroll()
          this.#ticking = false
        })
        this.#ticking = true
      }
    }

    #debounceUpdateLayout = () => {
      if (this.#debounceTimeout) clearTimeout(this.#debounceTimeout)
      this.#debounceTimeout = setTimeout(() => this.#updateMasonryLayout(), 100)
    }

    #handleResize = () => {
      if (this.#isMasonry) this.#debounceUpdateLayout()
    }

    #handleClickToggle = () => {
      if (this.#container) {
        this.#container.innerHTML = ''
        this.#container.style.cssText = ''
      }
      if (this.#loader) this.#loader.style.display = ''

      this.#isMasonry = !this.#isMasonry
      this.dataset.layout = this.#isMasonry ? 'masonry' : 'square'
      this.style.height = this.#isMasonry ? '0' : 'auto'

      this.#currentIndex = 0
      this.#isLoading = true
      this.#allLoaded = false

      this.#buildLayout()

      window.localStorage.setItem(
        this.#layoutStorageKey(),
        this.#isMasonry ? 'masonry' : 'square'
      )
    }

    // event delegation: open viewer when focus is on a figure and presses Enter
    #handleKeyOpen = (ev: KeyboardEvent) => {
      if (ev.defaultPrevented) return
      if (!(ev.key === 'Enter')) return

      const fig = (ev.target as HTMLElement)?.closest('.photo-figure')
      if (!fig) return

      const img = fig.querySelector('img')
      img?.click()
    }
  }

  if (!customElements.get('photo-view'))
    customElements.define('photo-view', PhotoView)
