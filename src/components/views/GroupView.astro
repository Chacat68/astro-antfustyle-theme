---
import { getCollection } from 'astro:content'

import Warning from '~/components/base/Warning.astro'
import Toc from '~/components/toc/Toc.astro'
import Categorizer from '~/components/base/Categorizer.astro'
import GroupItem from '~/components/views/GroupItem.astro'
import { FEATURES } from '~/config'
import { getLocale, useTranslations } from '~/i18n/translate'
import { pickLocalized } from '~/i18n/locales'

import type { CollectionKey } from 'astro:content'
import type { GroupItemData } from '~/components/views/GroupItem.astro'

interface Props {
  collectionType: CollectionKey
  pageToc: boolean
}

const { collectionType, pageToc } = Astro.props

const locale = getLocale(Astro.currentLocale)
const t = useTranslations(locale)

const WARNING = t('warning.noContentHtml', { file: 'GroupView.astro' })

let isEmpty = false
let data: Record<string, GroupItemData[]> = {}

/* Projects & Friends（desc/category 支持 *En 字段，英文路由 fallback 中文） */
if (collectionType === 'projects' || collectionType === 'friends') {
  const entries = await getCollection(collectionType)
  isEmpty = entries.length === 0

  data = entries
    .map((entry) => entry.data)
    .reduce(
      (
        acc: Record<string, GroupItemData[]>,
        { category, categoryEn, desc, descEn, ...rest }
      ) => {
        const localizedCategory = pickLocalized(locale, category, categoryEn)
        const localizedDesc = pickLocalized(locale, desc, descEn)
        ;(acc[localizedCategory] ??= []).push({ ...rest, desc: localizedDesc })
        return acc
      },
      {}
    )
}

/* Toc */
const { toc } = FEATURES
const tocEnabled = Array.isArray(toc) && toc[0] && pageToc
---

{
  isEmpty ? (
    <Warning html={WARNING} />
  ) : (
    <>
      {tocEnabled && (
        <Toc
          anchors={Object.keys(data)}
          style={
            toc[1].displayPosition === 'right' ? 'right: -5rem' : undefined
          }
        />
      )}
      {Object.keys(data).map((key, idx) => (
        <div class="slide-enter" style={{ '--enter-stage': idx }}>
          <Categorizer text={key} needId={tocEnabled} wide={true} />
          <GroupItem items={data[key]} />
        </div>
      ))}
    </>
  )
}
