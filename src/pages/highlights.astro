---
import BaseLayout from '~/layouts/BaseLayout.astro'
import StandardLayout from '~/layouts/StandardLayout.astro'
import CardView from '~/components/views/CardView.astro'
import { getLocale, useTranslations } from '~/i18n/translate'

const page = {
  bgType: false,
  toc: false,
  ogImage: false,
} as const

const locale = getLocale(Astro.currentLocale)
const t = useTranslations(locale)
---

<BaseLayout
  title={t('page.highlights.title')}
  description={t('page.highlights.description')}
  bgType={page.bgType}
  ogImage={page.ogImage}
  noindex={true}
>
  <StandardLayout
    title={t('page.highlights.title')}
    subtitle={t('page.highlights.subtitle')}
    isCentered={true}
  >
    <CardView collectionType="highlights" mode="masonry" />
  </StandardLayout>
</BaseLayout>
