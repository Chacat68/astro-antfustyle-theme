---
import BaseLayout from '~/layouts/BaseLayout.astro'
import TabbedLayout from '~/layouts/TabbedLayout.astro'
import ListView from '~/components/views/ListView.astro'
import { getLocale, useTranslations } from '~/i18n/translate'

const page = {
  bgType: false,
  toc: false,
  ogImage: false,
} as const

const locale = getLocale(Astro.currentLocale)
const t = useTranslations(locale)
---

<BaseLayout
  title={t('page.streams.title')}
  description={t('page.streams.description')}
  bgType={page.bgType}
  ogImage={page.ogImage}
  noindex={true}
>
  <TabbedLayout subtitle={t('page.streams.subtitle')}>
    <ListView collectionType="streams" pageToc={page.toc} />
  </TabbedLayout>
</BaseLayout>
