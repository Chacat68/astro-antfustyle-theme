---
import BaseLayout from '~/layouts/BaseLayout.astro'
import PixelTown from '~/components/home/PixelTown.astro'
import LatestPosts from '~/components/widgets/LatestPosts.astro'
import { UI, SITE } from '~/config'
import { ensureTrailingSlash } from '~/utils/path'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { getLocale, useTranslations } from '~/i18n/translate'

const page = {
  bgType: false,
  ogImage: false,
} as const

const socialLabel = (title: string) => {
  if (title === 'Github') return 'GitHub'
  const onIndex = title.lastIndexOf(' on ')
  return onIndex >= 0 ? title.slice(onIndex + 4) : title
}

const locale = getLocale(Astro.currentLocale)
const t = useTranslations(locale)
const blogHref = ensureTrailingSlash(getRelativeLocaleUrl(locale, 'blog'))
const projectsHref = ensureTrailingSlash(
  getRelativeLocaleUrl(locale, 'projects')
)
---

<BaseLayout
  title={t('page.home.title')}
  description={t('page.home.description')}
  bgType={page.bgType}
  ogImage={page.ogImage}
>
  <div class="home-sim">
    <header class="home-sim__hero slide-enter-instant">
      <p class="home-sim__brand">{SITE.title}</p>
      <h1 class="home-sim__title">{t('home.town.headline')}</h1>
      <p class="home-sim__lead">{t('home.town.lead')}</p>
      <div class="home-sim__cta">
        <a href={blogHref} class="home-sim__btn home-sim__btn--primary">
          {t('home.town.ctaBlog')}
        </a>
        <a href={projectsHref} class="home-sim__btn home-sim__btn--ghost">
          {t('home.town.ctaProjects')}
        </a>
      </div>
    </header>

    <PixelTown />

    <article class="home-sim__body prose slide-enter-content">
      <p>{t('home.intro1')}</p>
      <p>{t('home.intro2')}</p>

      <p class="home-roles">
        <strong>{t('home.roles')}</strong>
      </p>

      <hr />

      <LatestPosts limit={8} />

      <hr />

      <div class="home-socials">
        <div class="mb-2">{t('home.findMeOn')}</div>
        <div class="home-social-links flex flex-wrap gap-2">
          {
            UI.socialLinks.map((item) => (
              <a
                href={item.link}
                title={item.title}
                class="inline-flex items-center gap-1.5 op-75 hover:op-100"
              >
                {'icon' in item && (
                  <span class={item.icon} aria-hidden="true" />
                )}
                <span>{socialLabel(item.title)}</span>
              </a>
            ))
          }
        </div>
      </div>

      <hr />

      <p>{t('home.thanks')}</p>
    </article>
  </div>
</BaseLayout>
