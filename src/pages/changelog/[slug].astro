---
import RenderPost from '~/components/views/RenderPost.astro'
import { getFilteredPosts } from '~/utils/data'
import { getLocale } from '~/i18n/translate'

import {
  isDefaultLocale,
  DEFAULT_LOCALE,
  type AppLocale,
} from '~/i18n/locales'

export async function getStaticPaths() {
  const posts = await getFilteredPosts('changelog')

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
const locale = getLocale(Astro.currentLocale)
const isEnglishFallback = !isDefaultLocale(locale)
const availableLocales: AppLocale[] = [DEFAULT_LOCALE]
const canonicalLocale: AppLocale = DEFAULT_LOCALE
---

<RenderPost
  {post}
  {availableLocales}
  {canonicalLocale}
  noindex={isEnglishFallback}
/>
