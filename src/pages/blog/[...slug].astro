---
import RenderPost from '~/components/views/RenderPost.astro'
import { getCollection, getEntry } from 'astro:content'

import { getLocale } from '~/i18n/translate'

import type { CollectionEntry } from 'astro:content'
import { isDefaultLocale, DEFAULT_LOCALE, type AppLocale } from '~/i18n/locales'

let englishPostsById: Map<string, CollectionEntry<'blog_en'>> | undefined

async function getEnglishPostsById() {
  if (!englishPostsById) {
    const posts = await getCollection('blog_en', ({ data }) => {
      return import.meta.env.PROD ? !data.draft : true
    })
    englishPostsById = new Map(posts.map((post) => [post.id, post]))
  }

  return englishPostsById
}

export async function getStaticPaths() {
  // Use zh posts as the source of truth for slugs.
  const posts = await getCollection('blog', ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true
  })

  return posts.map((post) => ({
    params: { slug: post.id },
  }))
}

const locale = getLocale(Astro.currentLocale)
const slug = Astro.params.slug
if (!slug) throw new Error('Missing blog post slug')

const englishPost = (await getEnglishPostsById()).get(slug)
const hasEnglishTranslation = Boolean(englishPost)

// 英文路由优先使用译稿；无译稿时回退中文并 noindex，避免重复收录
const post = !isDefaultLocale(locale)
  ? (englishPost ?? (await getEntry('blog', slug)))
  : await getEntry('blog', slug)

if (!post) throw new Error(`Blog post not found: ${slug}`)

const isEnglishFallback = !isDefaultLocale(locale) && !hasEnglishTranslation
const availableLocales: AppLocale[] = hasEnglishTranslation
  ? [DEFAULT_LOCALE, 'en']
  : [DEFAULT_LOCALE]
const canonicalLocale: AppLocale = isEnglishFallback ? DEFAULT_LOCALE : locale
---

<RenderPost
  {post}
  isCommentable={true}
  {availableLocales}
  {canonicalLocale}
  noindex={isEnglishFallback}
/>
