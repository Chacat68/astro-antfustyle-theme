---
import BaseLayout from '~/layouts/BaseLayout.astro'
import TabbedLayout from '~/layouts/TabbedLayout.astro'
import ListView from '~/components/views/ListView.astro'
import { getLocale, useTranslations } from '~/i18n/translate'

const page = {
  bgType: 'glitch',
  toc: true,
  ogImage: false,
} as const

const locale = getLocale(Astro.currentLocale)
const t = useTranslations(locale)
---

<BaseLayout
  title={t('page.feeds.title')}
  description={t('page.feeds.description')}
  bgType={page.bgType}
  ogImage={page.ogImage}
  noindex={true}
>
  <TabbedLayout subtitle={t('page.feeds.subtitle')}>
    <ListView collectionType="feeds" pageToc={page.toc} />
  </TabbedLayout>
</BaseLayout>
