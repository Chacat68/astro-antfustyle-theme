# 复制为 .env 并按需填写。变量以 PUBLIC_ 开头会暴露到客户端 bundle。
# 文档：https://docs.astro.build/en/guides/environment-variables/

# 设为 false 可关闭生产环境全部统计脚本（默认开启，但需下方各自配置 ID/URL）
# PUBLIC_ENABLE_ANALYTICS=false

# Umami（需同时配置 SRC 与 WEBSITE_ID 才会加载；值须与后台「Tracking code」一致）
# 生产为跨域：https://umami.chawfoo.com/script.js（已写入 public/_headers 的 script-src / connect-src）
# PUBLIC_UMAMI_SRC=https://umami.chawfoo.com/script.js
# PUBLIC_UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Ahrefs Site Audit 追踪（配置后才会加载）
# PUBLIC_AHREFS_KEY=

# GitHub API（构建时拉取 Releases/PRs，可选）
# GITHUB_TOKEN=
